---
import heroImg from '../../assets/games/tower-defense/images/unit/figure_rpg_character_yuusya.png';
import warriorImg from '../../assets/games/tower-defense/images/unit/figure_rpg_character_kenshi.png';
import mageImg from '../../assets/games/tower-defense/images/unit/figure_rpg_character_mahoutsukai.png';
import fighterImg from '../../assets/games/tower-defense/images/unit/figure_rpg_character_butouka.png';
---
<!-- Start Screen -->
<div class="td-wrapper">
  <!-- Global Back Button -->
  <div id="global-back-btn" class="global-back-btn" style="display: none;" title="戻る">◀</div>

  <div class="overlay" id="start-screen">
    <h2 class="title-main">横スクロールタワーディフェンス</h2>
    <p class="desc-sub">コストを払ってユニットを召喚し、拠点を防衛しよう！<br>※スタートするとBGMが鳴ります</p>
    <button id="start-btn" class="btn btn-primary start-btn-wide">スタート</button>
    <button id="howto-btn" class="btn btn-secondary start-btn-wide howto-margin">遊び方</button>
    <button id="reset-save-btn" class="btn"
      style="position: absolute; bottom: 1.5rem; right: 1.5rem; padding: 0.4rem 0.8rem; background: transparent; border: 1px solid #ff4444; color: #ff4444; font-size: 0.75rem;">データリセット</button>
    <span id="start-config-btn" class="icon-config" title="コンフィグ">⚙️</span>
  </div>

  <!-- Reset Confirm Modal -->
  <div class="overlay modal-dim" id="reset-confirm-modal">
    <div class="modal-inner" style="text-align: center;">
      <h2 class="modal-title" style="color: #ff4444;">データリセット</h2>
      <div style="margin: 2rem 0;">
        <p>セーブデータを初期化しますか？</p>
        <p style="font-size: 0.9rem; color: #ccc;">この操作は取り消せません。</p>
      </div>
      <div style="display: flex; gap: 1rem; justify-content: center;">
        <button id="btn-reset-cancel" class="btn btn-secondary">キャンセル</button>
        <button id="btn-reset-execute" class="btn btn-primary"
          style="background: #ff4444; border-color: #ff4444;">リセットする</button>
      </div>
    </div>
  </div>

  <!-- How-to Modal -->
  <div class="overlay modal-dim" id="howto-modal">
    <div class="modal-inner">
      <h2 class="modal-title">遊び方</h2>
      <div class="howto-content">
        <p>・時間経過で「コスト」がたまります。</p>
        <p>・コストを払ってユニットを召喚し、迫りくる敵から拠点を防衛してください。</p>
        <p>・「ベースキャンプ」でゴールドを使ってユニットを強化できます。</p>
      </div>
      <button id="close-howto-btn" class="btn btn-secondary btn-full-width">閉じる</button>
    </div>
  </div>

  <!-- Wave Cut-in -->
  <div id="wave-cutin" class="wave-cutin-container">
    <div class="wave-cutin-box">
      <h2 id="wave-cutin-text" class="wave-cutin-title">WAVE 1</h2>
      <button id="btn-wave-ok" class="btn btn-primary wave-cutin-btn">OK</button>
    </div>
  </div>

  <!-- Map Screen -->
  <div class="overlay" id="map-screen">
    <span id="map-config-btn" class="icon-config" title="コンフィグ">⚙️</span>
    <h2 class="modal-title">ステージ選択</h2>
    <div class="stage-buttons">
      <button id="btn-stage1" class="btn btn-stage">ステージ1 (森)</button>
      <button id="btn-stage2" class="btn btn-stage" disabled>ステージ2 (夕)</button>
      <button id="btn-stage3" class="btn btn-stage" disabled>ステージ3 (夜)</button>
    </div>
    <button id="btn-to-upgrade" class="btn btn-basecamp btn-to-upgrade">ベースキャンプ (強化)</button>
  </div>

  <!-- Upgrade Screen -->
  <div class="overlay" id="upgrade-screen">
    <span id="upgrade-config-btn" class="icon-config" title="コンフィグ">⚙️</span>
    <h2 class="basecamp-title">ベースキャンプ</h2>
    <div class="upgrade-header" style="display:flex; justify-content:space-between; align-items:center; margin: 0 auto 10px auto; width: 100%; max-width: 400px; padding: 0 10px;">
      <div class="basecamp-tabs" style="display:flex; gap: 10px; flex: 1; max-width: 240px;">
        <button id="tab-btn-unit" class="btn btn-primary" style="flex: 1; padding: 0.3rem 0;">ユニット</button>
        <button id="tab-btn-base" class="btn btn-secondary" style="flex: 1; padding: 0.3rem 0;">拠点</button>
      </div>
      <span class="upgrade-gold" style="font-size:1.2rem; font-weight:bold; color:#ffd700;"><span id="upgrade-gold-display">0</span> G</span>
    </div>

    <div id="tab-content-unit" class="upgrade-list">      <!-- Shield -->
      <div class="upgrade-item-container" id="upg-container-shield">
        <div class="upgrade-unit-card">
          <img src={warriorImg.src} class="unit-card-img" alt="戦士">
        </div>
        <div class="upgrade-info-cols">
          <div class="upgrade-col-name">
            <div class="upgrade-lv">Lv: <span id="lv-shield">1</span></div>
            <div class="upgrade-unit-name">戦士</div>
          </div>
          <div class="upgrade-col-stats">
            <div>HP: <span id="upg-hp-shield">200</span> / 攻撃: <span id="upg-atk-shield">30</span></div>
            <div>速: <span id="upg-spd-shield">30</span> / 射程: 短</div>
          </div>
        </div>
        <button id="btn-upg-shield" class="btn btn-primary btn-upgrade">強化<br>(<span
            id="cost-shield">150</span>G)</button>
      </div>

      <!-- Mage -->
      <div class="upgrade-item-container" id="upg-container-mage">
        <div class="upgrade-unit-card">
          <img src={mageImg.src} class="unit-card-img" alt="魔法使い">
        </div>
        <div class="upgrade-info-cols">
          <div class="upgrade-col-name">
            <div class="upgrade-lv">Lv: <span id="lv-mage">1</span></div>
            <div class="upgrade-unit-name">魔法使い</div>
          </div>
          <div class="upgrade-col-stats">
            <div>HP: <span id="upg-hp-mage">40</span> / 攻撃: <span id="upg-atk-mage">100</span></div>
            <div>速: <span id="upg-spd-mage">40</span> / 射程: 長</div>
          </div>
        </div>
        <button id="btn-upg-mage" class="btn btn-primary btn-upgrade">強化<br>(<span id="cost-mage">200</span>G)</button>
      </div>

      <!-- Fighter -->
      <div class="upgrade-item-container" id="upg-container-butouka">
        <div class="upgrade-unit-card">
          <img src={fighterImg.src} class="unit-card-img" alt="格闘家">
        </div>
        <div class="upgrade-info-cols">
          <div class="upgrade-col-name">
            <div class="upgrade-lv">Lv: <span id="lv-butouka">1</span></div>
            <div class="upgrade-unit-name">格闘家</div>
          </div>
          <div class="upgrade-col-stats">
            <div>HP: <span id="upg-hp-butouka">50</span> / 攻撃: <span id="upg-atk-butouka">10</span></div>
            <div>速: <span id="upg-spd-butouka">80</span> / 射程: 短</div>
          </div>
        </div>
        <button id="btn-upg-butouka" class="btn btn-primary btn-upgrade">強化<br>(<span
            id="cost-butouka">100</span>G)</button>
      </div>

      <!-- Sword -->
      <div class="upgrade-item-container" id="upg-container-sword">
        <div class="upgrade-unit-card">
          <img src={heroImg.src} class="unit-card-img" alt="勇者">
        </div>
        <div class="upgrade-info-cols">
          <div class="upgrade-col-name">
            <div class="upgrade-lv">Lv: <span id="lv-sword">1</span></div>
            <div class="upgrade-unit-name">勇者</div>
          </div>
          <div class="upgrade-col-stats">
            <div>HP: <span id="upg-hp-sword">300</span> / 攻撃: <span id="upg-atk-sword">50</span></div>
            <div>速: <span id="upg-spd-sword">50</span> / 射程: 中</div>
          </div>
        </div>
        <button id="btn-upg-sword" class="btn btn-primary btn-upgrade">強化<br>(<span
            id="cost-sword">100</span>G)</button>
      </div>
    </div> <!-- /tab-content-unit -->

    <!-- Base Upgrade Tab Content -->
    <div id="tab-content-base" class="upgrade-list" style="display:none;">
      
      <!-- Base HP -->
      <div class="upgrade-item-container" id="upg-container-base-hp">
        <div class="upgrade-unit-card" style="border-color: #32cd32;"><div style="font-size: 1.5rem;">❤️</div></div>
        <div class="upgrade-info-cols">
          <div class="upgrade-col-name"><span class="upgrade-unit-name">拠点耐久力</span><span class="upgrade-lv">Lv.<span id="upg-lv-base-hp">1</span></span></div>
          <div class="upgrade-col-stats"><div style="font-size:0.8rem; color:#88f;">拠点の最大HPが1増加する</div></div>
        </div>
        <button id="btn-upg-base-hp" class="btn btn-primary btn-upgrade">強化<br>(<span id="cost-base-hp">500</span>G)</button>
      </div>

      <!-- Base Stats -->
      <div class="upgrade-item-container" id="upg-container-base-stats">
        <div class="upgrade-unit-card" style="border-color: #ff4500;"><div style="font-size: 1.5rem;">⚔️</div></div>
        <div class="upgrade-info-cols">
          <div class="upgrade-col-name"><span class="upgrade-unit-name">ユニット能力</span><span class="upgrade-lv">Lv.<span id="upg-lv-base-stats">1</span></span></div>
          <div class="upgrade-col-stats"><div style="font-size:0.8rem; color:#88f;">全味方のHPと攻撃力 +5%</div></div>
        </div>
        <button id="btn-upg-base-stats" class="btn btn-primary btn-upgrade">強化<br>(<span id="cost-base-stats">500</span>G)</button>
      </div>

      <!-- Base Cost -->
      <div class="upgrade-item-container" id="upg-container-base-cost">
        <div class="upgrade-unit-card" style="border-color: #1e90ff;"><div style="font-size: 1.5rem;">💧</div></div>
        <div class="upgrade-info-cols">
          <div class="upgrade-col-name"><span class="upgrade-unit-name">コスト効率</span><span class="upgrade-lv">Lv.<span id="upg-lv-base-cost">1</span></span></div>
          <div class="upgrade-col-stats"><div style="font-size:0.8rem; color:#88f;">初期コストと回復量が +5%</div></div>
        </div>
        <button id="btn-upg-base-cost" class="btn btn-primary btn-upgrade">強化<br>(<span id="cost-base-cost">500</span>G)</button>
      </div>

      <!-- Base Gold -->
      <div class="upgrade-item-container" id="upg-container-base-gold">
        <div class="upgrade-unit-card" style="border-color: #ffd700;"><div style="font-size: 1.5rem;">💰</div></div>
        <div class="upgrade-info-cols">
          <div class="upgrade-col-name"><span class="upgrade-unit-name">獲得ゴールド</span><span class="upgrade-lv">Lv.<span id="upg-lv-base-gold">1</span></span></div>
          <div class="upgrade-col-stats"><div style="font-size:0.8rem; color:#88f;">敵撃破時の獲得Gが +2G</div></div>
        </div>
        <button id="btn-upg-base-gold" class="btn btn-primary btn-upgrade">強化<br>(<span id="cost-base-gold">500</span>G)</button>
      </div>
    </div> <!-- /tab-content-base -->
  </div> <!-- /upgrade-screen -->
  <!-- Result Screen -->
  <div class="overlay" id="result-screen">
    <span id="result-config-btn" class="icon-config" title="コンフィグ">⚙️</span>
    <h2 id="result-title">ゲームオーバー</h2>
    <p id="result-message">防衛に失敗しました...</p>
    <div class="result-buttons">
      <button id="btn-retry" class="btn btn-secondary">リトライ</button>
      <button id="btn-title" class="btn btn-secondary">マップへ戻る</button>
      <button id="btn-share" class="btn btn-twitter">Xでシェア</button>
    </div>
  </div>

  <!-- Retire Modal -->
  <div class="overlay modal-dim" id="retire-modal">
    <div class="modal-inner">
      <h2 class="modal-title-retire">リタイアしますか？</h2>
      <div class="stage-buttons stage-buttons-no-margin">
        <button id="btn-retire-yes" class="btn btn-danger">はい</button>
        <button id="btn-retire-no" class="btn btn-secondary">いいえ</button>
      </div>
    </div>
  </div>

  <!-- Config Modal -->
  <div class="overlay modal-dim" id="config-modal">
    <div class="modal-inner">
      <h2 class="modal-title">コンフィグ</h2>
      <div class="config-item">
        <label class="config-label">BGM音量</label>
        <input type="range" id="bgm-volume" class="config-range" min="0" max="100" value="50">
      </div>
      <div class="config-item config-item-last">
        <label class="config-label">SE音量</label>
        <input type="range" id="se-volume" class="config-range" min="0" max="100" value="50">
      </div>
      <button id="close-config-btn" class="btn btn-secondary btn-full-width">閉じる</button>
    </div>
  </div>

  <!-- Game UI Options -->
  <div class="game-ui-header">
    <div class="status-bar" style="padding-left: 3.5rem;">
      <div>WAVE: <span id="wave-display">1 / 3</span></div>
      <div class="text-hp">拠点: <span id="base-hp-display">3 / 3</span></div>
      <div class="text-コスト">コスト: <span id="コスト-display">0</span></div>
      <div class="text-gold"><span id="gold-display">0</span> G</div>
      <span id="config-btn" class="icon-config config-btn-inline" title="コンフィグ">⚙️</span>
    </div>
  </div>

  <div class="game-ui">

    <div class="action-bar-inner">
      <button id="btn-retire" class="btn btn-danger btn-retire">リタイア</button>
    </div>

    <div class="deck-area">
      <button class="unit-card" id="btn-spawn-shield">
        <img src={warriorImg.src} class="unit-card-img" alt="戦士">
        <div class="unit-name">戦士</div>
        <div class="unit-cost"><span id="deck-cost-shield">50</span> M</div>
      </button>
      <button class="unit-card" id="btn-spawn-mage">
        <img src={mageImg.src} class="unit-card-img" alt="魔法使い">
        <div class="unit-name">魔法使い</div>
        <div class="unit-cost"><span id="deck-cost-mage">70</span> M</div>
      </button>
      <button class="unit-card" id="btn-spawn-butouka">
        <img src={fighterImg.src} class="unit-card-img" alt="格闘家">
        <div class="unit-name">格闘家</div>
        <div class="unit-cost"><span id="deck-cost-butouka">20</span> M</div>
      </button>
      <button class="unit-card" id="btn-spawn-sword">
        <img src={heroImg.src} class="unit-card-img" alt="勇者">
        <div class="unit-name">勇者</div>
        <div class="unit-cost"><span id="deck-cost-sword">100</span> M</div>
      </button>
    </div>

  </div>

  <style>
    /* タワーディフェンス個別のスタイル */
    .game-container {
      height: 600px;
    }

    /* overlay基底クラス: position:absolute で game-container を全面覆う。初期非表示。
     JSで style.display = 'flex' / 'none' に切り替えて画面遷移を管理する。 */
    .overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      box-sizing: border-box;
      z-index: 10;
    }

    .overlay.active {
      display: flex !important;
    }

    #start-screen {
      display: flex;
    }

    #start-screen,
    #map-screen,
    #result-screen {
      background-color: var(--bg-color, #1a1a2e);
    }

    #upgrade-screen {
      background-color: var(--bg-color, #1a1a2e);
      justify-content: flex-start;
      overflow: hidden;
      padding: 1rem;
      box-sizing: border-box;
    }

    /* Wave Cut-in */
    .wave-cutin-container {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      display: none;
      z-index: 50;
      overflow: hidden;
    }

    .wave-cutin-container.active {
      display: flex;
      align-items: center;
      background: rgba(0, 0, 0, 0.4);
      pointer-events: auto;
    }

    .wave-cutin-box {
      width: 100%;
      background: rgba(220, 53, 69, 0.85);
      color: white;
      padding: 2rem 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .wave-cutin-container.active .wave-cutin-box {
      transform: translateX(0);
    }

    .wave-cutin-container.slide-out .wave-cutin-box {
      transform: translateX(-100%);
    }

    .wave-cutin-title {
      font-size: 3rem;
      font-style: italic;
      margin-bottom: 1rem;
      text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
    }

    .wave-cutin-btn {
      font-size: 1.5rem;
      padding: 0.5rem 4rem;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.5);
    }

    /* Inline style replacements */
    .title-main {
      margin-bottom: 0.5rem;
      font-size: 2rem;
    }

    .desc-sub {
      color: var(--text-muted);
      margin-bottom: 2rem;
      font-size: 0.85rem;
    }

    .start-btn-wide {
      width: 80%;
      max-width: 300px;
    }

    .howto-margin {
      margin-top: 1rem;
    }

    .modal-dim {
      background-color: rgba(0, 0, 0, 0.85);
      z-index: 40;
    }

    .modal-title {
      margin-bottom: 1.5rem;
    }

    .modal-title-retire {
      margin-bottom: 1.5rem;
      font-size: 1.5rem;
    }

    .howto-content {
      text-align: left;
      color: #ccc;
      margin-bottom: 1.5rem;
      line-height: 1.6;
      font-size: 0.9rem;
    }

    .btn-full-width {
      width: 100%;
      max-width: 300px;
    }

    .btn-to-upgrade {
      width: 80%;
      max-width: 300px;
      padding: 0.8rem;
      margin: 0 auto;
      display: block;
    }

    .basecamp-title {
      margin-bottom: 1rem;
      font-size: 1.5rem;
    }

    #result-message {
      margin-bottom: 2rem;
    }

    .btn-twitter {
      background-color: #1DA1F2;
      border-color: #1DA1F2;
      color: white;
    }

    .stage-buttons-no-margin {
      margin-bottom: 0;
    }

    .config-item {
      margin-bottom: 1rem;
      text-align: left;
    }

    .config-item-last {
      margin-bottom: 2rem;
      text-align: left;
    }

    .config-label {
      display: block;
      margin-bottom: 0.5rem;
      color: #aaa;
    }

    .config-range {
      width: 100%;
    }

    .text-コスト {
      color: #00d2ff;
    }

    .text-hp {
      color: #32cd32;
    }

    .text-gold {
      color: #ffd700;
    }

    .config-btn-inline {
      cursor: pointer;
      margin-left: auto;
      display: flex;
      align-items: center;
      line-height: 1;
      font-size: 1.4rem;
    }

    .action-bar-inner {
      position: absolute;
      right: 10px;
      bottom: 10px;
      pointer-events: none;
      z-index: 6;
    }

    .global-back-btn {
      position: absolute;
      top: 10px;
      left: 10px;
      width: 36px;
      height: 36px;
      background: rgba(0, 0, 0, 0.6);
      color: white;
      display: flex;
      justify-content: center;
      align-items: center;
      border-radius: 4px;
      cursor: pointer;
      font-size: 1.2rem;
      z-index: 50;
      /* over all screens */
      transition: background 0.2s;
    }

    .global-back-btn:hover {
      background: rgba(0, 0, 0, 0.9);
    }

    .btn-retire {
      display: none !important;
    }

    .btn-stage {
      padding: 1rem 2rem;
      font-size: 1.2rem;
      background: #00d2ff;
      color: white;
      border: 2px solid white;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
    }

    .btn-stage.stage-cleared {
      background: #ffd700;
      color: #1a1a2e;
      border-color: #fff;
      font-weight: bold;
    }

    .btn-stage.stage-cleared::after {
      content: "\A CLEAR!";
      white-space: pre;
      font-size: 0.8rem;
      display: block;
      line-height: 1;
      margin-top: 0.2rem;
    }

    .btn-stage:disabled {
      background: #3a3a4c;
      color: #777;
      border-color: #333;
      box-shadow: none;
      cursor: not-allowed;
    }

    /* Original styles */
    .stage-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 2rem;
      justify-content: center;
    }

    .btn-basecamp {
      background-color: #4b0082;
      color: white;
      border-color: #4b0082;
    }

    .btn-basecamp:hover {
      background-color: #3a0066;
    }

    .btn-danger {
      background-color: #dc3545;
      color: white;
      border-color: #dc3545;
    }

    .btn-danger:hover {
      background-color: #c82333;
    }

    .upgrade-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      max-width: 500px;
      margin-bottom: 1rem;
    }

    .upgrade-gold {
      font-weight: bold;
      color: #ffd700;
    }

    .upgrade-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 100%;
      max-width: 500px;
      padding-bottom: 2rem;
      flex: 1;
      overflow-y: auto;
      padding-right: 0.5rem;
      /* Scrollbar spacing */
    }

    .unit-name {
      color: white;
      font-weight: bold;
      font-size: 0.9rem;
    }

    .upgrade-stats {
      width: 100%;
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.5rem;
    }

    .upgrade-lv {
      font-weight: bold;
    }

    .upgrade-hp-atk {
      font-size: 0.8rem;
      color: #aaa;
