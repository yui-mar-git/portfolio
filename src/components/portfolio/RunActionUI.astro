---
const { gameTitle } = Astro.props;
---
<div class="game-container" id="game-container">
  <!-- Game Area (Canvas) -->
  <!-- HUD (Score / Highscore) -->
  <div class="game-hud" id="game-hud">
    <div class="time-display">記録: <span id="survival-time">0.0</span>秒</div>
    <div class="highscore-display global-style-hrir4f" >
      ベスト: <span id="highscore">0.0</span>秒
      <span id="hud-config-btn" class="icon-config global-style-sypb5s" title="コンフィグ"
        >⚙️</span>
    </div>
  </div>
  <div class="bottom-hud global-style-736gi5" id="bottom-hud"
    >
    <button id="retire-btn" class="btn btn-danger global-style-5vllo3" >リタイア</button>
  </div>
  <canvas id="game-canvas"></canvas>

  <!-- Screens -->
  <div class="overlay" id="start-screen">
    <div style="position: absolute; top: 1rem; left: 1rem; font-weight: bold; color: var(--text-muted);">
      ベスト: <span id="start-highscore-val">0.0</span>秒
    </div>
    <h2>{gameTitle || 'エンドレス・ラン！'}</h2>
    <p class="start-desc">スタートで走り出します</p>
    <button id="start-btn" class="btn btn-full">スタート</button>
    <button id="howto-btn" class="btn btn-secondary btn-full btn-howto">遊び方</button>
    <span id="config-btn" class="icon-config global-style-d5t1mq" title="コンフィグ" >⚙️</span>
  </div>

  <div class="overlay" id="result-screen">
    <p>記録: <span id="final-time" class="highlight">0.0</span> 秒</p>
    <div class="result-actions">
      <button id="retry-btn" class="btn btn-secondary btn-full">リトライ</button>
      <button id="title-btn" class="btn btn-secondary btn-full">タイトルへ</button>
      <button id="share-btn" class="btn btn-primary btn-full btn-share">Xでシェア</button>
    </div>
  </div>



  <style>
    .game-hud {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      box-sizing: border-box;
      background: rgba(0, 0, 0, 0.5);
      padding: 0.5rem 1rem;
      z-index: 5;
      pointer-events: none;
      color: white;
      display: none;
      justify-content: space-between;
      font-size: 1rem;
      font-weight: bold;
    }

    .highscore-display {
      color: white;
    }

    /* game-containerの高さと背景色: 天の空 */
    #game-container {
      --game-height: 450px;
      background: #87CEEB; 
    }

    :global([data-theme="dark"]) #game-container {
      background: #1a2a40; /* 夜の空 */
    }

    canvas {
      display: block;
      width: 100%;
      height: 100%;
      touch-action: none;
    }

    #result-screen {
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background-color: rgba(0, 0, 0, 0.6);
    }

    .start-desc {
      color: var(--text-muted);
      margin-bottom: 2rem;
      font-size: 0.85rem;
    }

    /* タイトル画面の遊び方ボタン */
    .btn-howto {
      margin-top: 1rem;
      width: 100%;
    }

    .btn-full {
      width: 100%;
      max-width: 300px;
      margin-left: auto;
      margin-right: auto;
    }

    .btn-share {
      background-color: #1DA1F2;
      border-color: #1DA1F2;
    }

    /* コンフィグ内ボタン: 遊び方（上）→ クレジット（下）の間隔 */
    .btn-config-howto {
      margin-bottom: 0.5rem;
    }

    .btn-danger {
      background-color: #dc3545;
      color: white;
      border-color: #dc3545;
    }

    .btn-danger:hover {
      background-color: #c82333;
    }

    .result-actions {
      display: flex;
      flex-direction: column;
      width: 80%;
      max-width: 300px;
      gap: 1rem;
      margin-top: 2rem;
      margin-left: auto;
      margin-right: auto;
    }

    .howto-content {
      text-align: left;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
      line-height: 1.6;
    }

    /* 遊び方モーダルのページテキスト */
    .howto-page {
      text-align: left;
      line-height: 1.8;
    }
    .howto-text {
      color: var(--text-muted);
      margin: 0;
    }

    .credits-list {
      margin-top: 1rem;
      padding-left: 1.5rem;
    }

    /* overlay基底クラス: デフォルト非表示。JSで display:flex に切り替える */
    .overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.6);
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      z-index: 10;
    }

    /* start-screen は初期状態で表示。背景色も指定 */
    #start-screen {
      display: flex;
      background-color: var(--bg-color);
    }

    .overlay h2 {
      color: #fff;
      margin-bottom: 1rem;
      font-size: 2rem;
    }

    .overlay p {
      color: #f8f9fa;
      margin-bottom: 2rem;
      font-weight: bold;
    }

    .highlight {
      font-size: 2.5rem;
      color: #ffea00;
      margin: 0 0.5rem;
    }

/* Auto-extracted styles */
.global-style-hrir4f { display: flex; align-items: center; }
.global-style-sypb5s { position: relative; top: auto; right: auto; margin-left: 0.5rem; cursor: pointer; pointer-events: auto; }
.global-style-736gi5 { position: absolute; bottom: 1rem; right: 1rem; z-index: 5; display: none; pointer-events: auto; }
.global-style-5vllo3 { padding: 0.5rem 1rem; font-size: 0.9rem; }
.global-style-d5t1mq { cursor: pointer; }
.global-style-c5yyf6 { margin-top: 1.5rem; }

  </style>