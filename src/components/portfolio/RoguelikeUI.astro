---
import imgYuusya from '../../assets/games/roguelike/images/characters/figure_rpg_character_yuusya.png';
import imgKenshi from '../../assets/games/roguelike/images/characters/figure_rpg_character_kenshi.png';
import imgMahoutsukai from '../../assets/games/roguelike/images/characters/figure_rpg_character_mahoutsukai.png';
import imgButouka from '../../assets/games/roguelike/images/characters/figure_rpg_character_butouka.png';
import imgHotelPet from '../../assets/games/roguelike/images/map/building_hotel_pet.png';
import imgPixy from '../../assets/games/roguelike/images/characters/fantasy_pixy2.png';
import imgShop from '../../assets/games/roguelike/images/map/omise_shop_tatemono.png';
import imgNoImage from '../../assets/games/roguelike/images/icons/no_image_square.jpg';
import imgKing from '../../assets/games/roguelike/images/characters/royal_king.png';
---
<!-- game-container: CSSで position:relative / height:580px / overflow:hidden を定義済み -->
<div class="game-container" id="game-container">
  <!-- icon-config: CSSで position/top/right/z-index を定義 -->
  <span id="config-btn" class="icon-config" title="コンフィグ">⚙️</span>

  <!-- ゲームヘッダーバー（ステータス常時表示） -->
  <!-- game-header-bar: CSSで定義。初期 display:none はCSS側で管理 -->
  <div id="game-header" class="game-header-bar">
    <div class="header-status">
      <span id="header-floor" class="header-floor">エリア 1 - 0層</span>
      <span class="gold-badge">💰<span id="header-gold">50</span></span>
      <span class="hp-badge">❤️<span id="header-hp">10/10</span></span>
      <span class="mp-badge">💧<span id="header-mp">5/5</span></span>
      <div class="header-relics">
        <span class="header-relics-label">レリック:</span>
        <div id="header-relics-list" class="header-relics-list"></div>
      </div>
    </div>
  </div>

  <!-- ゲームオーバー/クリア画面 -->
  <div class="overlay result-overlay" id="result-overlay">
    <h2 id="result-title">戦闘終了</h2>
    <p id="result-details" class="result-details"></p>
    <div class="result-actions">
      <button class="btn btn-primary" id="btn-next">次の戦闘へ</button>
      <button class="btn btn-secondary" id="btn-title">タイトルへ</button>
      <button class="btn btn-share" id="btn-share">Xでシェア</button>
    </div>
  </div>

  <!-- カード選択報酬画面 -->
  <div class="overlay reward-overlay" id="reward-overlay">
    <h2>🎉 戦闘勝利！</h2>
    <p class="reward-subtitle" id="reward-subtitle-text">1枚カードを選んでデッキに追加</p>
    <div id="reward-cards" class="reward-cards"></div>
    <button class="btn btn-secondary btn-skip-reward" id="btn-skip-reward">スキップ</button>
  </div>

  <!-- デッキ閲覧モーダル -->
  <div class="overlay deck-viewer-overlay" id="deck-viewer-overlay">
    <h2 class="deck-viewer-title">デッキ確認</h2>
    <div class="deck-viewer-tabs">
      <button class="deck-tab active" data-target="deck-list">山札 (<span id="dv-deck-count">0</span>)</button>
      <button class="deck-tab" data-target="discard-list">捨て札 (<span id="dv-discard-count">0</span>)</button>
      <button class="deck-tab" data-target="hand-list">手札 (<span id="dv-hand-count">0</span>)</button>
    </div>
    <div id="deck-list" class="dv-card-list active"></div>
    <div id="discard-list" class="dv-card-list"></div>
    <div id="hand-list" class="dv-card-list"></div>
    <button class="btn btn-secondary btn-full btn-mt" id="close-deck-viewer">閉じる</button>
  </div>

  <!-- スタート画面 -->
  <!-- start-screen: CSS で position/background/z-index 定義 -->
  <div id="start-screen" class="game-screen start-screen">
    <h2 class="screen-title">ローグライクカードゲーム</h2>
    <p class="screen-desc">職業・属性・状態異常・ゴールドを駆使する本格ローグライク<br>※スタートするとBGMが鳴ります</p>
    <button id="start-btn" class="btn btn-full">冒険を始める</button>
    <button id="howto-btn" class="btn btn-secondary btn-full btn-mt">遊び方</button>
  </div>

  <!-- 職業選択画面 -->
  <div id="class-select-screen" class="game-screen class-select-screen">
    <h2 class="class-select-title">冒険者の選択</h2>
    <p class="class-select-desc">あなたの戦闘スタイルを選んで旅立ちましょう。</p>
    <div class="class-select-body">
      <div class="class-grid">
        <div class="class-card" data-class="yuusya">
          <img src={imgYuusya.src} style="width: 40px; height: 40px; object-fit: contain; margin-bottom: 0.3rem;" />
          <div style="font-size: 0.85rem; font-weight: bold;">勇者</div>
          <div style="font-size: 0.62rem; color: var(--text-muted); line-height: 1.3; margin-top: 0.25rem;">HP10 /
            MP5<br>初期レリックが+1個</div>
        </div>
        <div class="class-card" data-class="kenshi">
          <img src={imgKenshi.src} style="width: 40px; height: 40px; object-fit: contain; margin-bottom: 0.3rem;" />
          <div style="font-size: 0.85rem; font-weight: bold;">戦士</div>
          <div style="font-size: 0.62rem; color: var(--text-muted); line-height: 1.3; margin-top: 0.25rem;">HP15 /
            MP4<br>毎ターンHP+1回復</div>
        </div>
        <div class="class-card" data-class="mahoutsukai">
          <img src={imgMahoutsukai.src}
            style="width: 40px; height: 40px; object-fit: contain; margin-bottom: 0.3rem;" />
          <div style="font-size: 0.85rem; font-weight: bold;">魔法使い</div>
          <div style="font-size: 0.62rem; color: var(--text-muted); line-height: 1.3; margin-top: 0.25rem;">HP7 /
            MP7<br>毎ターンMP+1回復</div>
        </div>
        <div class="class-card" data-class="butouka">
          <img src={imgButouka.src} style="width: 40px; height: 40px; object-fit: contain; margin-bottom: 0.3rem;" />
          <div style="font-size: 0.85rem; font-weight: bold;">格闘家</div>
          <div style="font-size: 0.62rem; color: var(--text-muted); line-height: 1.3; margin-top: 0.25rem;">HP8 /
            MP4<br>毎ターン行動回数+1</div>
        </div>
      </div>
      <p id="class-select-preview"
        style="font-size: 0.7rem; color: #ffb84d; text-align: center; margin-top: 0.8rem; min-height: 1.2rem;">
        勇者が選択されています</p>
    </div>

    <button id="btn-game-start" class="btn btn-full btn-mt">冒険の旅へ出る</button>
  </div>

  <!-- マップ進行画面（横スクロール双六マップ） -->
  <div id="map-screen" class="game-screen game-screen-offset">
    <div class="map-header">
      <h3 class="map-title">マップ</h3>
    </div>

    <!-- 横スクロールすごろく本体 -->
    <div id="map-scroll-wrapper" class="map-scroll-wrapper">
      <div id="map-board" class="map-board">
        <!-- JSですごろくノードが左から右に動的描画されます。接続線はCSSまたはSVG -->
      </div>
    </div>

    <div class="map-footer">
      <button class="btn btn-secondary btn-deck-view" id="btn-map-view-deck">デッキ確認</button>
      <span class="map-hint">接続された次のマスへ進めます</span>
    </div>
  </div>

  <!-- 宿（回復）画面 -->
  <div id="inn-screen" class="game-screen game-screen-offset inn-screen">
    <div class="screen-box-image-wrap">
      <img src={imgHotelPet.src} style="width: 100px; height: 100px; object-fit: contain;" />
    </div>
    <h3 style="color: #51cf66; font-size: 1.2rem; margin-bottom: 0.5rem;">旅人の宿</h3>
    <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 1.5rem; max-width: 80%;">
      15ゴールドを支払って、宿屋でぐっすり休むことができます。<br>
      <strong>効果: HP全回復 ＋ 毒/麻痺の全治</strong>
    </p>
    <div class="screen-actions">
      <button id="btn-inn-rest" class="btn btn-primary btn-full">休む (💰15)</button>
      <button id="btn-inn-leave" class="btn btn-secondary btn-full">立ち去る</button>
    </div>
  </div>

  <!-- 妖精（強化）画面 -->
  <div id="fairy-screen" class="game-screen game-screen-offset fairy-screen">
    <div style="text-align: center;">
      <div class="screen-box-image-wrap">
        <img src={imgPixy.src} style="width: 100px; height: 100px; object-fit: contain;" />
      </div>
      <h3 style="color: #cc5de8; font-size: 1.2rem; margin-bottom: 0.2rem;">祝福の妖精</h3>
      <p id="fairy-desc" style="font-size: 0.75rem; color: var(--text-muted);">
        20ゴールドを支払い、妖精の魔力で手札のカードを1枚「強化（+）」します。</p>
    </div>

    <!-- 強化対象カード選択リスト -->
    <div id="fairy-card-list"
      style="flex: 1; overflow-y: auto; margin: 1rem 0; display: grid; grid-template-columns: repeat(6, 1fr); gap: 6px; padding: 4px; border: 1px solid #333; border-radius: 6px; background: rgba(0,0,0,0.3); max-height: 250px;">
      <!-- 所持カードがボタンとして並びます -->
    </div>

    <div class="screen-actions">
      <button id="btn-fairy-leave" class="btn btn-secondary btn-flex">立ち去る</button>
    </div>
  </div>

  <!-- 街（ショップ）画面 -->
  <div id="town-screen" class="game-screen game-screen-offset town-screen">
    <div style="text-align: center;">
      <div class="screen-box-image-wrap">
        <img src={imgShop.src} style="width: 100px; height: 100px; object-fit: contain;" />
      </div>
      <h3 style="color: #ff922b; font-size: 1.2rem; margin-bottom: 0.2rem;">よろず街の商い</h3>
      <p style="font-size: 0.75rem; color: var(--text-muted);">ゴールドを支払い、アイテムやカードを仕入れることができます。</p>
    </div>

    <div
      style="flex: 1; display: flex; flex-direction: column; gap: 10px; margin: 0.8rem 0; overflow-y: auto; max-height: 280px;">
      <div>
        <p
          style="font-size: 0.72rem; color: #ff922b; font-weight: bold; margin-bottom: 0.3rem; border-bottom: 1px solid #444;">
          販売カード (各 💰15)</p>
        <div id="town-cards" style="display: flex; gap: 6px; overflow-x: auto; padding: 4px 0;"></div>
      </div>
      <div>
        <p
          style="font-size: 0.72rem; color: #ffd8a8; font-weight: bold; margin-bottom: 0.3rem; border-bottom: 1px solid #444;">
          販売アイテム (各 💰20)</p>
        <div id="town-items" style="display: flex; gap: 6px; overflow-x: auto; padding: 4px 0;"></div>
      </div>
    </div>

    <button id="btn-town-leave" class="btn btn-secondary btn-full">街を出る</button>
  </div>

  <!-- イベント画面 -->
  <div id="event-screen" class="game-screen game-screen-offset event-screen">
    <div>
      <div class="screen-box-image-wrap">
        <img id="event-image" src={imgNoImage.src}
          style="width: 100px; height: 100px; object-fit: contain; border-radius: 4px;" />
      </div>
      <h3 id="event-title" style="color: #ffb84d; font-size: 1.2rem; margin-bottom: 0.5rem;">未知のイベント</h3>
      <p id="event-text"
        style="font-size: 0.82rem; color: var(--text-muted); line-height: 1.6; max-width: 90%; margin: 1rem auto;">
      </p>
    </div>

    <div id="event-options" style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
      <!-- イベントの選択肢ボタンがJSで動的に追加されます -->
    </div>
  </div>

  <!-- アイテム使用確認モーダル -->
  <div id="item-confirm-modal"
    style="position:absolute; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:300; display:none; flex-direction:column; align-items:center; justify-content:center; padding:1.5rem; box-sizing:border-box;">
    <div
      style="background: #151522; border: 1px solid #444; border-radius: 8px; padding: 1.2rem; width: 85%; max-width: 320px; text-align: center;">
      <h4 style="font-size: 1rem; color: #ffb84d; margin-bottom: 0.4rem;">アイテムの使用確認</h4>
      <p id="item-confirm-text"
        style="font-size: 0.78rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 1.2rem;"></p>
      <div style="display: flex; gap: 10px;">
        <button id="btn-item-confirm-yes" class="btn btn-primary" style="flex: 1; padding: 0.4rem 0;">はい</button>
        <button id="btn-item-confirm-no" class="btn btn-secondary" style="flex: 1; padding: 0.4rem 0;">いいえ</button>
      </div>
    </div>
  </div>

  <!-- 戦闘中マップ確認モーダル -->
  <div id="battle-map-overlay" class="overlay"
    style="display: none; background-color: rgba(0,0,0,0.9); z-index: 250; padding: 1rem; flex-direction: column;">
    <h3 style="color: #ffb84d; font-size: 1.1rem; text-align: center; margin-bottom: 0.5rem;">現在地確認</h3>
    <div id="battle-map-scroll-wrapper"
      style="flex: 1; overflow-x: auto; overflow-y: hidden; display: flex; align-items: center; background: rgba(0,0,0,0.3); border: 1px solid #333; border-radius: 8px; padding: 1.5rem 1rem;">
      <div id="battle-map-board"
        style="display: flex; gap: 40px; align-items: center; position: relative; min-width: max-content;"></div>
    </div>
    <button class="btn btn-secondary" id="btn-close-battle-map" style="margin-top: 0.8rem; width: 100%;">閉じる</button>
  </div>

  <!-- 王様遭遇イベントモーダル -->
  <div id="king-event-modal" class="overlay"
    style="display: none; background-color: rgba(15,15,26,0.98); z-index: 210; flex-direction: column; align-items: center; justify-content: center; padding: 1.5rem; text-align: center;">
    <div class="screen-box-image-wrap">
      <img src={imgKing.src} style="width: 100px; height: 100px; object-fit: contain;" />
    </div>
    <h3 style="color: #ffd700; font-size: 1.2rem; margin-bottom: 0.4rem;">謁見の間：王からの餞別</h3>
    <p style="font-size: 0.8rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 1.5rem; max-width: 80%;">
      「よくぞ来た、勇猛なる旅人よ。この地に巣食う魔王を討ち果たすのだ。<br>お前にこの伝説の遺物（レリック）から一つを授けよう…」
    </p>
    <div id="king-relic-choices" style="display: flex; gap: 10px; margin-bottom: 1.5rem;">
      <!-- 3つのレリック選択カードがJSで挿入されます -->
    </div>
  </div>

  <!-- 汎用カットシーンモーダル -->
  <div id="cutscene-modal" class="overlay"
    style="display: none; background: rgba(5,5,20,0.97); z-index: 300; flex-direction: column; align-items: center; justify-content: flex-end; padding-bottom: 2rem;">
    <!-- 背景イメージ -->
    <div id="cutscene-bg"
      style="position:absolute; inset:0; background-size:cover; background-position:center; opacity:0.25; pointer-events:none;">
    </div>
    <!-- キャラクターポートレート群 -->
    <div id="cutscene-portraits"
      style="position:absolute; bottom:120px; left:0; right:0; display:flex; align-items:flex-end; justify-content:center; gap:20px; pointer-events:none; z-index:2;">
    </div>
    <!-- セリフウィンドウ -->
    <div
      style="position:relative; z-index:3; width:92%; max-width:420px; background:rgba(10,8,25,0.92); border:2px solid #6a5acd; border-radius:12px; padding:1rem 1.2rem 0.8rem; box-shadow:0 0 30px rgba(106,90,205,0.4);">
      <div id="cutscene-speaker"
        style="font-size:0.72rem; font-weight:bold; color:#c9b8ff; margin-bottom:0.3rem; min-height:1em;"></div>
      <div id="cutscene-text" style="font-size:0.78rem; color:#e8e0ff; line-height:1.7; min-height:3.2em;"></div>
      <div style="text-align:right; margin-top:0.5rem;">
        <button id="btn-cutscene-next" class="btn btn-primary" style="font-size:0.7rem; padding:0.25rem 1rem;">次へ
          ▶</button>
      </div>
    </div>
  </div>

  <!-- ゲーム内汎用メッセージダイアログ -->

  <div id="game-dialog-modal" class="overlay"
    style="display: none; background-color: rgba(0,0,0,0.85); z-index: 500; align-items: center; justify-content: center; padding: 1.5rem;">
    <div
      style="background: #151522; border: 2px solid #555; border-radius: 10px; padding: 1.2rem; width: 85%; max-width: 320px; text-align: center; box-shadow: 0 0 15px rgba(0,0,0,0.5);">
      <h4 id="dialog-title" style="font-size: 1rem; color: #ffb84d; margin-bottom: 0.5rem; font-weight: bold;">通知
      </h4>
      <p id="dialog-message" style="font-size: 0.78rem; color: #eee; line-height: 1.5; margin-bottom: 1.2rem;">
      </p>
      <div id="dialog-buttons" style="display: flex; gap: 10px; justify-content: center;">
        <button id="btn-dialog-ok" class="btn btn-primary" style="padding: 0.3rem 1.5rem;">OK</button>
        <button id="btn-dialog-yes" class="btn btn-primary" style="display:none; flex:1; padding: 0.3rem 0;">はい</button>
        <button id="btn-dialog-no" class="btn btn-secondary"
          style="display:none; flex:1; padding: 0.3rem 0;">いいえ</button>
      </div>
    </div>
  </div>

  <!-- バトル画面本体 -->
  <div class="battle-layout"
    style="top: 40px; height: calc(100% - 40px); position: absolute; width: 100%; display: none; box-sizing: border-box; padding: 0.4rem 0.5rem 0.3rem;">

    <!--バトルフィールド -->
    <div class="battle-field"
      style="display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 85px 85px; gap: 20px; padding: 10px; margin-bottom: 0.3rem; position: relative; background: linear-gradient(180deg, rgba(30,15,5,0.6) 0%, rgba(5,15,30,0.6) 100%); border-radius: 8px; overflow: hidden; border: 1px solid #333;">

      <!-- ① 左上：敵ステータス -->
      <div class="enemy-status-panel"
        style="padding: 0.4rem 0.5rem; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; background: rgba(0,0,0,0.75); border: 1px solid #666; border-radius: 8px; z-index: 2; transform: translateX(20px); align-self: center; box-shadow: 2px 2px 8px rgba(0,0,0,0.6);">
        <div
          style="font-size: 0.78rem; font-weight: bold; color: #e8d5b7; display: flex; align-items: center; gap: 4px; margin-bottom: 0.15rem;">
          <span id="enemy-name">敵</span>
          <span id="enemy-poison-badge" style="font-size: 0.65rem; display: none;"></span>
        </div>
        <div style="display: flex; align-items: center; gap: 4px; width: 100%;">
          <span style="font-size: 0.62rem; color: #ccc; flex-shrink: 0;">HP</span>
          <div
            style="flex: 1; height: 8px; background: #2a1a1a; border-radius: 4px; overflow: hidden; border: 1px solid #555;">
            <div id="enemy-hp-bar"
              style="height: 100%; background: linear-gradient(90deg, #e74c3c, #e67e22); width: 100%; transition: width 0.3s;">
            </div>
          </div>
          <span id="enemy-hp-text"
            style="font-size: 0.62rem; color: #e8d5b7; white-space: nowrap; flex-shrink: 0;">40/40</span>
        </div>
        <div id="enemy-intent"
          style="font-size: 0.6rem; color: #ffb84d; margin-top: 0.15rem; display: none; background: rgba(0,0,0,0.5); border-radius: 3px; padding: 1px 4px; border: 1px solid #666;">
          ⚔️ 5</div>
      </div>

      <!-- ② 右上：敵画像 -->
      <div style="display: flex; align-items: center; justify-content: center; position: relative;">
        <img id="enemy-image" src="" alt="敵"
          style="width: 72px; height: 72px; object-fit: contain; filter: drop-shadow(2px 2px 4px rgba(0,0,0,0.8));" />
      </div>

      <!-- ③ 左下：自分画像 -->
      <div
        style="display: flex; align-items: center; justify-content: flex-start; padding-left: 0.5rem; position: relative;">
        <img id="player-battle-image" src="" alt="自分"
          style="width: 72px; height: 72px; object-fit: contain; filter: drop-shadow(-2px 2px 4px rgba(0,0,50,0.8));" />
      </div>

      <!-- ④ 右下：自分ステータス -->
      <div class="player-status-panel"
        style="padding: 0.4rem 0.5rem; display: flex; flex-direction: column; justify-content: center; align-items: flex-end; background: rgba(0,0,50,0.75); border: 1px solid #007bff; border-radius: 8px; z-index: 2; transform: translateX(-20px); align-self: center; box-shadow: -2px 2px 8px rgba(0,0,0,0.6);">
        <div
          style="font-size: 0.78rem; font-weight: bold; color: #b7d5e8; display: flex; align-items: center; gap: 4px; margin-bottom: 0.15rem;">
          <span id="player-poison-badge" style="font-size: 0.65rem; display: none;"></span>
          <span id="player-class-name">あなた</span>
        </div>
        <div style="display: flex; align-items: center; gap: 4px; width: 100%;">
          <span style="font-size: 0.62rem; color: #ccc; flex-shrink: 0;">HP</span>
          <div
            style="flex: 1; height: 8px; background: #1a1a2a; border-radius: 4px; overflow: hidden; border: 1px solid #555;">
            <div id="player-hp-bar"
              style="height: 100%; background: linear-gradient(90deg, #27ae60, #2ecc71); width: 100%; transition: width 0.3s;">
            </div>
          </div>
          <span id="player-hp-text"
            style="font-size: 0.62rem; color: #b7d5e8; white-space: nowrap; flex-shrink: 0;">10/10</span>
        </div>
        <div style="display: flex; align-items: center; gap: 4px; width: 100%; margin-top: 0.1rem;">
