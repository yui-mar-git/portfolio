---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { MicroCMSPortfolio } from '../types/microcms';

export interface TechItem {
  category: string;
  items: string;
}

export interface MaterialItem {
  name: string;
  url: string;
}

export interface MaterialCategory {
  category: string;
  items: MaterialItem[];
}

export interface Props {
  title: string;
  pageId: string;
  pageLabel: string;
  projectData?: MicroCMSPortfolio;
  descriptionFallback: string;
  techStack: TechItem[];
  learningThemes: string[];
  materialCategories: MaterialCategory[];
}

const {
  title,
  pageId,
  pageLabel,
  projectData,
  descriptionFallback,
  techStack,
  learningThemes,
  materialCategories
} = Astro.props;
---
<BaseLayout title={title} pageId={pageId}>
  <Header activeId="portfolio" />

  <main class="container">
    <article>
      <div id="global-game-scaler" class="global-style-qjunur">
        <div id="global-game-scaler-inner" class="global-style-5jp6zk">
          <slot />
        </div>
      </div>

      <script is:inline>
        (function() {
          function applyScale() {
            const scaler = document.getElementById('global-game-scaler');
            const inner = document.getElementById('global-game-scaler-inner');
            if (!scaler || !inner) return;
            
            const container = inner.querySelector('.game-container') || inner.firstElementChild;
            if (!container) return;
            
            const style = window.getComputedStyle(container);
            const logicalWidth = parseInt(style.maxWidth) || parseInt(style.width) || 800;
            const logicalHeight = container.offsetHeight || parseInt(style.height) || 600;
            
            const parentWidth = scaler.parentElement.clientWidth;
            
            if (parentWidth < logicalWidth) {
              const scale = parentWidth / logicalWidth;
              inner.style.width = `${logicalWidth}px`;
              inner.style.transform = `scale(${scale})`;
              scaler.style.height = `${logicalHeight * scale}px`;
            } else {
              inner.style.width = '100%';
              inner.style.transform = 'none';
              scaler.style.height = `${logicalHeight}px`;
            }
          }
          
          window.addEventListener('resize', applyScale);
          document.addEventListener('DOMContentLoaded', applyScale);
          setTimeout(applyScale, 100);
          setTimeout(applyScale, 500);
          window.addEventListener('load', applyScale);
        })();
      </script>

      <!-- プロジェクト概要・使用技術セクション -->
      <section class="project-details">
        <h2>概要</h2>
        {projectData && (projectData.description || projectData.content) ? (
        <p class="description" set:html={(projectData.description || projectData.content).replace(/\n/g, '<br>')} />
        ) : (
        <p class="description">{descriptionFallback}</p>
        )}

        <h2>学習テーマ</h2>
        <div class="materials-list">
          <ul>
            {learningThemes.map((theme) => (
            <li>{theme}</li>
            ))}
          </ul>
        </div>

        <h2>使用技術・ツール</h2>
        <div class="table-responsive">
          <table class="tech-table">
            <tbody>
              {techStack.map((tech) => (
              <tr>
                <th>{tech.category}</th>
                <td>{tech.items}</td>
              </tr>
              ))}
            </tbody>
          </table>
        </div>

        {materialCategories.length > 0 && (
          <>
            <h2>使用素材</h2>
            <div class="table-responsive">
              <table class="tech-table">
                <tbody>
                  {materialCategories.map((mat) => (
                  <tr>
                    <th>{mat.category}</th>
                    <td>
                      {mat.items.map((item, index) => (
                      <span key={item.name}>
                        <a href={item.url} target="_blank" rel="noopener noreferrer">{item.name}</a>
                        {index < mat.items.length - 1 ? " / " : ""}
                      </span>
                      ))}
                    </td>
                  </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        )}
      </section>
    </article>
  </main>
  
  <Footer />
<style>
/* Auto-extracted styles */
.global-style-qjunur { width: 100%; overflow: hidden; position: relative; }
.global-style-5jp6zk { transform-origin: top left; transition: transform 0.2s ease-out; }

</style>
</BaseLayout>


