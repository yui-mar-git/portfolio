---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout title="送信完了" pageId="thanks">
  <Header activeId="thanks" />

  <main class="container">
    <article>
      <span class="page-label">THANKS</span>
      <h1>送信完了</h1>
      <section class="hero hero-thanks">
        <div>
          <div class="thanks-icon">✉️</div>
          <p class="thanks-text">
            お問い合わせありがとうございます。<br>
            （※これはデモ画面です。実際にはどこにも送信されていません）
          </p>
          <a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/contact/index.html`} class="btn btn-secondary">フォームに戻る</a>
        </div>
      </section>
    </article>
  </main>

  <Footer />
</BaseLayout>
