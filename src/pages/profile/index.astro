---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import CertTree from '@/components/CertTree.astro';
import { fetchMicroCMS } from '@/lib/microcms';
import type { MicroCMSSettings, MicroCMSProfile, MicroCMSListResponse } from '@/types/microcms';

const settings = await fetchMicroCMS<MicroCMSSettings>('settings');
  const profileResponse = await fetchMicroCMS<MicroCMSListResponse<MicroCMSProfile>>('profile', { limit: '100' });
    const allProfileItems = profileResponse.contents;

    // 資格以外のアイテムは静的にハードコードするため、ここではフェッチしたデータからフィルタリングしません。

      // 資格のグルーピング
      const certs = allProfileItems.filter(item => {
      const cat = Array.isArray(item.category) ? item.category[0] : item.category;
      return cat && (cat.includes('資格') || cat.includes('検定'));
      });

      const rankDefinitions = [
      { keywords: ['ITパスポート'], rank: 3, system: '情報処理技術者' },
      { keywords: ['基本情報技術者'], rank: 2, system: '情報処理技術者' },
      { keywords: ['応用情報技術者'], rank: 1, system: '情報処理技術者' },
      { keywords: ['FP技能士'], gradeBased: true, system: 'FP技能士' },
      { keywords: ['ウェブデザイン技能士'], gradeBased: true, system: 'ウェブデザイン技能士' }
      ];

      const systems: Record<string, (MicroCMSProfile & { rank: number })[]> = {};

        certs.forEach(cert => {
        let systemName = '';
        let rank = 99;

        const def = rankDefinitions.find(d => d.keywords.some(k => cert.name.includes(k)));

        if (def) {
        systemName = def.system;
        if (def.gradeBased) {
        const gradeMatch = cert.name.match(/([123])級/);
        rank = gradeMatch ? parseInt(gradeMatch[1]) : 99;
        } else {
        rank = def.rank as number;
        }
        } else {
        const gradeMatch = cert.name.match(/([123])級/);
        rank = gradeMatch ? parseInt(gradeMatch[1]) : 99;
        systemName = cert.name.replace(/[123]級/, '').trim();
        }

        if (!systems[systemName]) {
        systems[systemName] = [];
        }
        systems[systemName].push({ ...cert, rank });
        });

        // 各系統をランク順にソート
        Object.keys(systems).forEach(name => {
        systems[name].sort((a, b) => b.rank - a.rank);
        });
        ---

        <BaseLayout title="Profile" pageId="profile">
          <Header activeId="profile" />

          <main class="container">
            <article>
              <span class="page-label">PROFILE</span>
              <h1>自己紹介</h1>

              <section class="profile-intro">
                <p id="profile-title" class="profile-title-text">{settings.title}</p>
                <h2 id="profile-name-display" class="profile-name-text">{settings.name}</h2>
                <p id="profile-bio" class="profile-bio-text" set:html={settings.bio.replace(/\n/g, '<br>' )} />
              </section>

              <section>
                <h2>使用技術・ツール</h2>
                <div class="skill-grid">
                  <div class="profile-card skill-card" style="width: 100%; max-width: 800px; margin: 0 auto; box-sizing: border-box;">
                    <h3>フロントエンド</h3>
                    <ul>
                      <li><strong>HTML</strong></li>
                      <li><strong>CSS</strong></li>
                      <li><strong>JavaScript</strong></li>
                      <li><strong>TypeScript</strong></li>
                      <li><strong>Astro</strong></li>
                      <li><strong>Phaser 3</strong></li>
                    </ul>
                    
                    <h3 style="margin-top: 1.5rem;">バックエンド・CMS</h3>
                    <ul>
                      <li><strong>Node.js</strong></li>
                      <li style="opacity: 0.5;">PHP</li>
                      <li><strong>microCMS</strong></li>
                      <li style="opacity: 0.5;">WordPress</li>
                    </ul>
                    
                    <h3 style="margin-top: 1.5rem;">インフラ・ホスティング</h3>
                    <ul>
                      <li><strong>Cloudflare (Pages / Turnstile)</strong></li>
                      <li style="opacity: 0.5;">Kinsta</li>
                    </ul>
                    
                    <h3 style="margin-top: 1.5rem;">開発環境・ツール</h3>
                    <ul>
                      <li><strong>GitHub</strong></li>
                      <li><strong>Google Antigravity</strong></li>
                      <li style="opacity: 0.5;">Cursor</li>
                    </ul>
                    
                    <h3 style="margin-top: 1.5rem;">デザイン</h3>
                    <ul>
                      <li style="opacity: 0.5;">Figma</li>
                      <li style="opacity: 0.5;">Photoshop</li>
                    </ul>
                    
                    <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 2rem; text-align: right;">※本ページで使用していないものは薄文字</p>
                  </div>
                </div>
              </section>

              <section>
                <h2>保有資格・検定</h2>
                <div class="cert-tree-container">
                  <div class="cert-tree" id="cert-tree-root">
                    <ul>
                      <li>
                        <div class="cert-node root">資格</div>
                        <ul>
                          {Object.keys(systems).map(sysName => (
                          <CertTree items={systems[sysName]} />
                          ))}
                        </ul>
                      </li>
                    </ul>
                  </div>
                </div>
              </section>
            </article>
          </main>

          <Footer />
        </BaseLayout>