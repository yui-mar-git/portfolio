---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { fetchMicroCMS } from '../../../lib/microcms';
import type { MicroCMSListResponse, MicroCMSPortfolio } from '../../../types/microcms';

const portfolioResponse = await fetchMicroCMS<MicroCMSListResponse<MicroCMSPortfolio>>('portfolio');
  const projectData = portfolioResponse.contents.find((c) => c.url.includes('/tower-defense/'));

  const techStack = [
  { category: "開発言語", items: "HTML, CSS, JavaScript" },
  { category: "フレームワーク", items: "Astro, Phaser 3 (ゲームエンジン)" },
  { category: "その他ツール", items: "Claude, Gemini" }
];

const learningThemes = ["ゲームエンジン(Phaser 3)基礎", "Arcade Physicsによる衝突判定"];

const materials = [
  { name: "Google Fonts", url: "https://fonts.google.com/" },
  { name: "Simple Icons", url: "https://simpleicons.org/" }
];
---

  <BaseLayout title="タワーディフェンス - My Portfolio" pageId="tower-defense">
    <!-- Phaser 3 の CDN 読み込み -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/phaser@3.60.0/dist/phaser.min.js"></script>

    <Header activeId="portfolio" />

    <main class="container">
      <article>
        <span class="page-label">TOWER DEFENSE</span>
        <h1>{projectData ? projectData.title : 'タワーディフェンス（Phaser.js雛形）'}</h1>

        <!-- ここにPhaserのCanvasが挿入されます -->
        <div id="game-container" style="position: relative;">
          <!-- HUD (所持マナと出撃ボタン) -->
          <div class="game-ui" style="position: absolute; top: 0; left: 0; width: 100%; box-sizing: border-box; background: rgba(0,0,0,0.6); color: white; padding: 0.5rem 1rem; z-index: 5; display: flex; justify-content: space-between; align-items: center;">
            <div class="status-bar" style="display: flex; gap: 1rem; align-items: center;">
              <span>所持マナ: <strong id="mana-display">0</strong></span>
              <button class="btn btn-primary" id="btn-spawn">出撃 (コスト: 50)</button>
            </div>
          </div>
          <!-- スタート画面 -->
          <div class="overlay" id="start-screen" style="background-color: var(--bg-color); z-index: 10; display: flex; flex-direction: column; align-items: center; justify-content: center;">
            <h2>タワーディフェンス</h2>
            <p>マナを消費して出撃し、拠点を防衛しよう</p>
            <button id="start-btn" class="btn btn-full">スタート</button>
            <button id="howto-btn" class="btn btn-secondary" style="margin-top: 1rem; width: 100%;">遊び方</button>
                <span id="config-btn" class="icon-config" title="コンフィグ">⚙️</span>
          </div>
          <!-- 遊び方モーダル -->
          <div class="overlay" id="result-screen" style="display: none; background-color: var(--bg-color); z-index: 10; flex-direction: column; align-items: center; justify-content: center;">
            <h2>ゲームオーバー</h2>
            <div class="result-actions" style="display: flex; flex-direction: column; width: 80%; max-width: 300px; gap: 1rem; margin-top: 2rem; margin-left: auto; margin-right: auto;">
              <button class="btn btn-secondary" id="btn-retry" style="width: 100%;">リトライ</button>
              <button class="btn btn-secondary" id="btn-title" style="width: 100%;">タイトルへ</button>
              <button class="btn btn-primary" id="btn-share" style="background-color: #1DA1F2; border-color: #1DA1F2; width: 100%;">Xでシェア</button>
            </div>
          </div>
          <div id="howto-modal" class="config-modal">
            <h3>遊び方</h3>
            <div class="howto-content" style="text-align: left; color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.6;">
              <p>時間経過で貯まるマナを消費して味方を出撃させましょう。</p>
              <p>味方は自動で前進して敵と戦ってくれます。</p>
              <p>強力なユニットをタイミングよく出撃させ、迫りくる敵を倒して拠点を防衛してください！</p>
            </div>
            <button id="close-howto-btn" class="btn btn-secondary" style="width: 100%;">閉じる</button>
          </div>

          <!-- コンフィグモーダル（ダミー） -->
          <div id="modal-overlay" class="modal-overlay"></div>
          <div id="config-modal" class="config-modal">
            <h3>設定（コンフィグ）</h3>
            <div class="config-item">
              <label for="bgm-volume">BGM音量</label>
              <input type="range" id="bgm-volume" min="0" max="100" value="50">
            </div>
            <div class="config-item">
              <label for="se-volume">SE音量</label>
              <input type="range" id="se-volume" min="0" max="100" value="50">
            </div>
            
                <button id="credits-btn" class="btn btn-secondary" style="width: 100%; margin-bottom: 0.5rem;">クレジット・使用素材</button>
                <button id="close-config-btn" class="btn btn-secondary" style="width: 100%;">閉じる</button>
          </div>
          <!-- クレジットモーダル -->
          <div id="credits-modal" class="config-modal">
            <h3>クレジット・使用素材</h3>
            <div class="howto-content" style="text-align: left; color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.6;">
              <p>本ゲームは以下の素晴らしい素材を使用・お借りして制作されています。</p>
              <ul style="margin-top: 1rem; padding-left: 1.5rem;">
                <li>フォント: <a href="https://fonts.google.com/" target="_blank" rel="noopener noreferrer">Google Fonts</a></li>
                <li>アイコン: <a href="https://simpleicons.org/" target="_blank" rel="noopener noreferrer">Simple Icons</a></li>
              </ul>
            </div>
            <button id="close-credits-btn" class="btn btn-secondary" style="width: 100%;">閉じる</button>
          </div>
        </div>

        <!-- ゲーム概要・使用技術セクション -->
        <section class="project-details">
          <h2>概要</h2>
        {projectData && projectData.description ? (
          <p class="description" set:html={projectData.description.replace(/\n/g, '<br>')} />
        ) : (
          <p class="description">（概要を取得できませんでした。microCMSのURL設定をご確認ください）</p>
        )}

        <h2>学習テーマ</h2>
        <div class="materials-list">
          <ul>
            {learningThemes.map((theme) => (
              <li>{theme}</li>
            ))}
          </ul>
        </div>

        <h2>使用技術・ツール</h2>
        <div class="table-responsive">
          <table class="tech-table">
            <tbody>
              {techStack.map((tech) => (
              <tr>
                <th>{tech.category}</th>
                <td>{tech.items}</td>
              </tr>
              ))}
            </tbody>
          </table>
        </div>

          <h2>使用素材</h2>
          <div class="materials-list">
            <ul>
              {materials.map((material) => (
              <li>
                <a href={material.url} target="_blank" rel="noopener noreferrer">{material.name}</a>
              </li>
              ))}
            </ul>
          </div>
        </section>
      </article>
    </main>

    <Footer />
  </BaseLayout>

  <style>
    .game-ui {
      margin-top: 2rem;
      margin-bottom: 1rem;
      background: var(--bg-secondary);
      padding: 1rem;
      border-radius: 8px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .status-bar {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      font-size: 1.2rem;
    }

    #game-container {
      width: 100%;
      max-width: 800px;
      margin: 0 auto;
      border: 4px solid var(--border-color);
      border-radius: 8px;
      overflow: hidden;
    }

    /* Phaserが生成するcanvas要素をコンテナに合わせる */
    #game-container canvas {
      display: block;
      width: 100%;
      height: auto;
    }

    .overlay {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0, 0, 0, 0.7);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: white;
      z-index: 10;
    }
    .overlay h2 {
      margin-bottom: 1rem;
    }
    .overlay p {
      margin-bottom: 2rem;
      color: #fff;
    }

    /* --- 追加：プロジェクト概要セクションのスタイル --- */
    .project-details {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }
  .project-details h2 {
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
  }
  .project-details h2:first-of-type {
    margin-top: 0;
  }
  .description {
      line-height: 1.8;
      color: var(--text-muted);
    }

    .tech-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }

    .tech-table th,
    .tech-table td {
      padding: 1rem;
      border: 1px solid var(--border-color);
      text-align: left;
    }

    .tech-table th {
      background-color: var(--bg-secondary);
      width: 30%;
      font-weight: bold;
    }
  </style>

  <script is:inline>
    /**
     * ==========================================
     * タワーディフェンス（横スクロール）の基礎ロジック
     * ==========================================
     * 
     * このコードは本格的なゲームエンジン「Phaser 3」を使用しています。
     * 自作すると大変な「重なり判定」「大量のオブジェクト管理」「描画ループ」を
     * Phaserが裏側で全て処理してくれます。
     */

    // --- ゲームの状態（HTMLと共有する変数） ---
    let mana = 0;
    const manaDisplay = document.getElementById('mana-display');
    const btnSpawn = document.getElementById('btn-spawn');

    // --- Phaser メインシーンの定義 ---
    class MainScene extends Phaser.Scene {
      constructor() {
        // シーンの名前を定義
        super({ key: 'MainScene' });
      }

      // 1. 画像や音声の読み込み（今回は図形を使うため省略）
      preload() {
        // 【学習ポイント】
        // 素材ができたら、ここで this.load.image('cat', 'assets/cat.png'); のように読み込みます。
      }

      // 2. 初期配置（ゲーム開始時に1回だけ実行）
      create() {
        // 背景色を空色に設定
        this.cameras.main.setBackgroundColor('#87CEEB');

        // 地面を描画
        const ground = this.add.rectangle(400, 550, 800, 100, 0x228B22);

        // 【重要】オブジェクトグループ（配列の強化版）を作成
        // 味方と敵をグループで管理することで、一括処理や当たり判定が超簡単になります。
        this.allies = this.physics.add.group();
        this.enemies = this.physics.add.group();

        // 当たり判定（Overlap）の設定
        // 味方と敵が重なった時に `handleCombat` メソッドを呼び出す
        this.physics.add.overlap(this.allies, this.enemies, this.handleCombat, null, this);

        // --- 定期実行タイマー ---
        // 1秒ごとにマナを回復するタイマー
        this.time.addEvent({
          delay: 1000,
          callback: () => {
            mana += 10;
            this.updateUI();
          },
          loop: true
        });

        // 3秒ごとに敵を自動生成するタイマー
        this.time.addEvent({
          delay: 3000,
          callback: this.spawnEnemy,
          callbackScope: this,
          loop: true
        });

        // HTMLの出撃ボタンとPhaserの処理を連携
        btnSpawn.addEventListener('click', () => {
          if (mana >= 50) {
            mana -= 50;
            this.updateUI();
            this.spawnAlly();
          }
        });

        // 初期状態はポーズしておく
        this.scene.pause();
      }

      // 3. 毎フレーム実行される処理（通常は1秒間に60回）
      update(time, delta) {
        // 各キャラクターの行動（歩行か攻撃か）を毎フレーム更新する

        // 味方の処理
        this.allies.getChildren().forEach(ally => {
          if (ally.state === 'walk') {
            ally.body.setVelocityX(50); // 右へ歩く
          } else if (ally.state === 'attack') {
            ally.body.setVelocityX(0);  // 立ち止まる
          }
        });

        // 敵の処理
        this.enemies.getChildren().forEach(enemy => {
          if (enemy.state === 'walk') {
            enemy.body.setVelocityX(-40); // 左へ歩く
          } else if (enemy.state === 'attack') {
            enemy.body.setVelocityX(0);   // 立ち止まる
          }
        });

        // 画面外（左や右）に出たキャラクターを削除してメモリを節約
        this.allies.getChildren().forEach(ally => {
          if (ally.x > 850) ally.destroy();
        });
        this.enemies.getChildren().forEach(enemy => {
          if (enemy.x < -50) enemy.destroy(); // プレイヤーの拠点に到達したら本当はダメージ
        });
      }

      // --- カスタムメソッド ---

      // HTMLの表示を更新する
      updateUI() {
        manaDisplay.textContent = mana;
        btnSpawn.disabled = (mana < 50);
      }

      // 味方の生成
      spawnAlly() {
        // 【カスタマイズポイント】
        // this.add.sprite(...) に変えれば画像で表示できます！
        const ally = this.add.rectangle(50, 480, 40, 40, 0x0000FF);
        this.physics.add.existing(ally); // 物理エンジン（当たり判定）を付与

        ally.hp = 100;
        ally.attackPower = 10;
        ally.lastAttackTime = 0; // 最後に攻撃した時間（クールダウン管理用）
        ally.state = 'walk';     // 初期状態は「歩行」

        this.allies.add(ally);
      }

      // 敵の生成
      spawnEnemy() {
        const enemy = this.add.rectangle(850, 480, 40, 40, 0xFF0000);
        this.physics.add.existing(enemy);

        enemy.hp = 80;
        enemy.attackPower = 5;
        enemy.lastAttackTime = 0;
        enemy.state = 'walk';

        this.enemies.add(enemy);
      }

      // 衝突時の戦闘処理（毎フレーム重なっている間呼ばれ続ける）
      handleCombat(ally, enemy) {
        // 状態を「攻撃」に変更し、歩行を止める
        ally.state = 'attack';
        enemy.state = 'attack';

        // Phaserの現在時刻を取得
        const currentTime = this.time.now;

        // 味方の攻撃（クールダウン：1秒 = 1000ms）
        if (currentTime - ally.lastAttackTime > 1000) {
          enemy.hp -= ally.attackPower;
          ally.lastAttackTime = currentTime;

          // 攻撃したことを視覚的に表現（一瞬だけ白くする）
          enemy.fillColor = 0xFFFFFF;
          this.time.delayedCall(100, () => { if (enemy.active) enemy.fillColor = 0xFF0000; });
        }

        // 敵の攻撃（クールダウン：1.5秒 = 1500ms）
        if (currentTime - enemy.lastAttackTime > 1500) {
          ally.hp -= enemy.attackPower;
          enemy.lastAttackTime = currentTime;

          ally.fillColor = 0xFFFFFF;
          this.time.delayedCall(100, () => { if (ally.active) ally.fillColor = 0x0000FF; });
        }

        // HPが0以下になったら死亡処理
        if (enemy.hp <= 0) {
          enemy.destroy(); // オブジェクトを完全に削除
          ally.state = 'walk'; // 敵が死んだので再び歩き出す
          mana += 20; // 敵を倒した報酬
          this.updateUI();
        }

        if (ally.hp <= 0) {
          ally.destroy();
          enemy.state = 'walk';
          document.getElementById('result-screen').style.display = 'flex';
          this.scene.pause();
          // プレイヤー陣地（今回はally）が倒されたらゲームオーバー扱い
          document.getElementById('result-screen').style.display = 'flex';
          this.scene.pause();
        }
      }
    }

    // --- Phaser ゲームの設定と起動 ---
    const config = {
      type: Phaser.AUTO,
      width: 800,
      height: 600,
      parent: 'game-container',
      physics: {
        default: 'arcade',
        arcade: {
          debug: false
        }
      },
      scene: [MainScene]
    };

    // ゲームインスタンスの作成（初期状態でポーズされる）
    const game = new Phaser.Game(config);

    // --- タイトル画面とコンフィグ制御 ---
    const startScreen = document.getElementById('start-screen');
    const startBtn = document.getElementById('start-btn');
    const howtoBtn = document.getElementById('howto-btn');
    const closeHowtoBtn = document.getElementById('close-howto-btn');
    const howtoModal = document.getElementById('howto-modal');
    const configBtn = document.getElementById('config-btn');
        const closeConfigBtn = document.getElementById('close-config-btn');
        const configModal = document.getElementById('config-modal');
    
        const creditsBtn = document.getElementById('credits-btn');
        const closeCreditsBtn = document.getElementById('close-credits-btn');
        const creditsModal = document.getElementById('credits-modal');
    const modalOverlay = document.getElementById('modal-overlay');
    const resultScreen = document.getElementById('result-screen');
    const btnRetry = document.getElementById('btn-retry');
    const btnTitle = document.getElementById('btn-title');
    const btnShare = document.getElementById('btn-share');
    
    

    if (howtoBtn) howtoBtn.addEventListener('click', () => {
      howtoModal.classList.add('active');
      modalOverlay.classList.add('active');
    });
    if (closeHowtoBtn) closeHowtoBtn.addEventListener('click', () => {
      howtoModal.classList.remove('active');
      modalOverlay.classList.remove('active');
    });
    
        
    

        
        

    if (btnRetry) btnRetry.addEventListener('click', () => {
      resultScreen.style.display = 'none';
      game.scene.stop('MainScene');
      game.scene.start('MainScene');
      setTimeout(() => { game.scene.resume('MainScene'); }, 100);
    });

    if (btnTitle) btnTitle.addEventListener('click', () => {
      resultScreen.style.display = 'none';
      startScreen.style.display = 'flex';
      game.scene.stop('MainScene');
      game.scene.start('MainScene');
      setTimeout(() => { game.scene.pause('MainScene'); }, 100);
    });

    if (btnShare) btnShare.addEventListener('click', () => {
      const text = encodeURIComponent('タワーディフェンスで遊びました！\n#ミニゲーム #ポートフォリオ');
      const url = encodeURIComponent(window.location.href);
      window.open('https://twitter.com/intent/tweet?text=' + text + '&url=' + url, '_blank');
    });

    if (startBtn) startBtn.addEventListener('click', () => {
      startScreen.style.display = 'none';
      game.scene.resume('MainScene');
    });

    const _cfgBtn = document.getElementById('config-btn');
    if (_cfgBtn) {
      _cfgBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        document.getElementById('config-modal')?.classList.add('active');
        document.getElementById('modal-overlay')?.classList.add('active');
      });
      _cfgBtn.addEventListener('mousedown', (e) => e.stopPropagation());
      _cfgBtn.addEventListener('touchstart', (e) => e.stopPropagation());
    }
    const _closeCfgBtn = document.getElementById('close-config-btn');
    if (_closeCfgBtn) {
      _closeCfgBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        document.getElementById('config-modal')?.classList.remove('active');
        document.getElementById('modal-overlay')?.classList.remove('active');
      });
      _closeCfgBtn.addEventListener('mousedown', (e) => e.stopPropagation());
      _closeCfgBtn.addEventListener('touchstart', (e) => e.stopPropagation());
    }

    const _credBtn = document.getElementById('credits-btn');
    if (_credBtn) {
      _credBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        document.getElementById('config-modal')?.classList.remove('active');
              document.getElementById('credits-modal')?.classList.add('active');
        document.getElementById('modal-overlay')?.classList.add('active');
      });
      _credBtn.addEventListener('mousedown', (e) => e.stopPropagation());
      _credBtn.addEventListener('touchstart', (e) => e.stopPropagation());
    }
    const _closeCredBtn = document.getElementById('close-credits-btn');
    if (_closeCredBtn) {
      _closeCredBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        document.getElementById('credits-modal')?.classList.remove('active');
        document.getElementById('modal-overlay')?.classList.remove('active');
      });
      _closeCredBtn.addEventListener('mousedown', (e) => e.stopPropagation());
      _closeCredBtn.addEventListener('touchstart', (e) => e.stopPropagation());
    }
  </script>
















  </script>




