---
import GameLayout from '../../../layouts/GameLayout.astro';
import TowerDefenseUI from '../../../components/portfolio/TowerDefenseUI.astro';
import { fetchMicroCMS } from '../../../lib/microcms';
import type { MicroCMSListResponse, MicroCMSPortfolio } from '../../../types/microcms';

const portfolioResponse = await fetchMicroCMS<MicroCMSListResponse<MicroCMSPortfolio>>('portfolio');
  const projectData = portfolioResponse.contents.find((c) => c.url.includes('/tower-defense/'));

  const techStack = [
  { category: "開発言語", items: "HTML5, CSS3, JavaScript (ES6+)" },
  { category: "フレームワーク", items: "Astro (MIT License), Phaser 3 (MIT License)" },
  { category: "その他ツール", items: "Google Antigravity, Gemini, Claude" }
  ];

  const learningThemes = [
  "Phaser 3 を用いたゲームループの構築",
  "物理エンジン（Arcade Physics）による衝突判定と状態管理",
  "タワーディフェンスのWave管理とリソースシステム設計"
  ];

  const materialCategories = [
  { category: "画像・イラスト", items: [{ name: "いらすとや", url: "https://www.irasutoya.com/" }] },
  { category: "フォント", items: [{ name: "Google Fonts（SIL Open Font License 1.1）", url: "https://fonts.google.com/" }] },
  { category: "SE・BGM", items: [{ name: "効果音ラボ", url: "https://soundeffect-lab.info/" }, { name: "PANICPUMPKIN", url: "http://pansound.com/panicpumpkin/" }] },
  { category: "アイコン", items: [{ name: "Simple Icons（CC0 1.0 Universal）", url: "https://simpleicons.org/" }] }
  ];
  ---

  <GameLayout title={projectData ? `${projectData.title} - My Portfolio` : '横スクロールタワーディフェンス - My Portfolio' }
    pageId="tower-defense" pageLabel="DEFENSE GAME" projectData={projectData} descriptionFallback=""
    techStack={techStack} learningThemes={learningThemes} materialCategories={materialCategories}>
    <div class="game-container" id="game-container">
      <TowerDefenseUI />
    </div>
  </GameLayout>

  <script is:inline src="https://cdn.jsdelivr.net/npm/phaser@3.60.0/dist/phaser.min.js"></script>
  <script src="../../../scripts/tower-defense/main.js"></script>