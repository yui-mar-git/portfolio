---
export const pageTitle = "エンドレスラン";
import GameLayout from '../../../layouts/GameLayout.astro';
import RunActionUI from '../../../components/portfolio/RunActionUI.astro';
import { fetchMicroCMS } from '../../../lib/microcms';
import type { MicroCMSListResponse, MicroCMSPortfolio } from '../../../types/microcms';

const portfolioResponse = await fetchMicroCMS<MicroCMSListResponse<MicroCMSPortfolio>>('portfolio');
  const projectData = portfolioResponse.contents.find((c) => c.url.includes('/run-action/'));

  const techStack = [
  { category: "フロントエンド", items: "HTML, CSS, JavaScript, Astro" },
  { category: "バックエンド・CMS", items: "Node.js, microCMS" },
  { category: "インフラ・ホスティング", items: "Cloudflare (Pages)" },
  { category: "開発環境・ツール", items: "GitHub, Google Antigravity" }
  ];

  const learningThemes = ["requestAnimationFrameによるメインループ", "物理演算（重力・ジャンプ）の基礎"];

  const materialCategories = [
  { category: "フォント", items: [{ name: "Google Fonts（SIL Open Font License 1.1）", url: "https://fonts.google.com/" }] },
  { category: "SE・BGM", items: [{ name: "効果音ラボ", url: "https://soundeffect-lab.info/" }, { name: "PANICPUMPKIN", url: "http://pansound.com/panicpumpkin/" }] },
  { category: "アイコン", items: [{ name: "Simple Icons（CC0 1.0 Universal）", url: "https://simpleicons.org/" }] }
  ];
  ---

  <GameLayout title={projectData ? `${projectData.title} - My Portfolio` : 'エンドレス・ラン - My Portfolio' }
    pageId="run-action" pageLabel="ACTION GAME" projectData={projectData} descriptionFallback="" techStack={techStack}
    learningThemes={learningThemes} materialCategories={materialCategories}>
    <RunActionUI materialCategories={materialCategories} gameTitle={projectData?.title} />
    <script src="../../../scripts/run-action/main.js"></script>