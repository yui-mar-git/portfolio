---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
---

<BaseLayout title="エンドレス・ラン - My Portfolio" pageId="run-action">
  <Header activeId="portfolio" />

  <main class="container">
    <article>
      <span class="page-label">ACTION GAME</span>
      <h1>エンドレス・ラン！</h1>
      <p>画面をタップしてジャンプ！障害物を避け、穴を飛び越えよう。（空中でさらにもう1回ジャンプ可能です）</p>

      <div class="game-container">
        <!-- HUD (Score / Highscore) -->
        <div class="game-hud">
          <div class="time-display">生存時間: <span id="survival-time">0.0</span>秒</div>
          <div class="highscore-display">ベスト: <span id="highscore">0.0</span>秒</div>
        </div>

        <!-- Game Area (Canvas) -->
        <div class="canvas-wrapper" id="canvas-wrapper">
          <canvas id="game-canvas"></canvas>

          <!-- Screens -->
          <div class="overlay" id="start-screen">
            <h2>準備はいいですか？</h2>
            <p>画面タップでジャンプ<br>（2段ジャンプ可）</p>
            <button id="start-btn" class="btn btn-full">スタート</button>
          </div>

          <div class="overlay" id="result-screen" style="display: none;">
            <h2>ゲームオーバー</h2>
            <p>記録: <span id="final-time" class="highlight">0.0</span> 秒</p>
            <div class="result-actions">
              <button id="retry-btn" class="btn btn-secondary">もう一度</button>
              <button id="share-btn" class="btn btn-primary" style="background-color: #1DA1F2; border-color: #1DA1F2;">Xでシェア</button>
            </div>
          </div>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .game-container {
    margin-top: 2rem;
    background: var(--bg-secondary);
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .game-hud {
    display: flex;
    justify-content: space-between;
    font-size: 1.25rem;
    font-weight: bold;
    margin-bottom: 1rem;
    padding: 0 1rem;
    color: var(--text-color);
  }

  .highscore-display {
    color: var(--primary-color);
  }

  .canvas-wrapper {
    position: relative;
    width: 100%;
    /* アスペクト比を固定しつつレスポンシブにするためのハック、今回は固定高さにする */
    height: 400px;
    background: #87CEEB; /* 空の色のモック */
    border: 4px solid var(--border-color);
    border-radius: 8px;
    overflow: hidden;
  }

  /* ダークモード時の空の色調整 */
  :global([data-theme="dark"]) .canvas-wrapper {
    background: #1a2a40; 
  }

  canvas {
    display: block;
    width: 100%;
    height: 100%;
    touch-action: none; /* スマホでのスワイプによるスクロールを無効化 */
  }

  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    z-index: 10;
  }

  .overlay h2 {
    color: #fff;
    margin-bottom: 1rem;
    font-size: 2rem;
  }

  .overlay p {
    color: #f8f9fa;
    margin-bottom: 2rem;
    font-weight: bold;
  }

  .highlight {
    font-size: 2.5rem;
    color: #ffea00;
    margin: 0 0.5rem;
  }

  .result-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }
</style>

<script is:inline>
  (function() {
    const canvas = document.getElementById('game-canvas');
    const ctx = canvas.getContext('2d');
    const wrapper = document.getElementById('canvas-wrapper');
    
    // UI Elements
    const startScreen = document.getElementById('start-screen');
    const resultScreen = document.getElementById('result-screen');
    const timeElement = document.getElementById('survival-time');
    const highscoreElement = document.getElementById('highscore');
    const finalTimeElement = document.getElementById('final-time');
    const startBtn = document.getElementById('start-btn');
    const retryBtn = document.getElementById('retry-btn');
    const shareBtn = document.getElementById('share-btn');

    // State
    let gameState = 'start'; // start, playing, gameover
    let startTime = 0;
    let survivalTime = 0;
    let highScore = parseFloat(localStorage.getItem('runaction_highscore')) || 0;
    highscoreElement.textContent = highScore.toFixed(1);

    // Canvas Resize (レスポンシブ対応)
    function resizeCanvas() {
      // 内部解像度をコンテナのサイズに合わせる
      canvas.width = wrapper.clientWidth;
      canvas.height = wrapper.clientHeight;
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    // Physics & Game Settings
    const gravity = 0.5;
    const jumpPower = -10;
    let scrollSpeed = 5;
    
    // Game Objects
    const player = {
      x: 50,
      y: 0,
      width: 30,
      height: 30,
      vy: 0,
      jumpCount: 0,
      maxJumps: 2
    };

    let blocks = [];
    let obstacles = [];
    let mountains = [];
    let clouds = [];
    let nextBlockX = 0;
    const blockWidth = 60;
    const blockHeight = 40;

    // Collision Detection (AABB)
    function checkCollision(r1, r2) {
      return r1.x < r2.x + r2.width &&
             r1.x + r1.width > r2.x &&
             r1.y < r2.y + r2.height &&
             r1.y + r1.height > r2.y;
    }

    // Main Game Loop
    function update() {
      if (gameState !== 'playing') return;

      // Update survival time
      const now = Date.now();
      survivalTime = (now - startTime) / 1000;
      timeElement.textContent = survivalTime.toFixed(1);

      // スピードアップ（徐々に難易度を上げる）
      scrollSpeed = 5 + (survivalTime / 10);

      // --- プレイヤーの物理演算 ---
      player.vy += gravity;
      player.y += player.vy;

      // --- 地形・障害物・背景のスクロール ---
      for (let i = 0; i < blocks.length; i++) {
        blocks[i].x -= scrollSpeed;
      }
      for (let i = 0; i < obstacles.length; i++) {
        obstacles[i].x -= scrollSpeed;
      }
      // 山のスクロール（速度は地面の0.5倍＝パララックス効果）
      for (let i = 0; i < mountains.length; i++) {
        mountains[i].x -= scrollSpeed * 0.5;
        // 画面左外に出たら右側にループさせる
        if (mountains[i].x + mountains[i].width < 0) {
          mountains[i].x = canvas.width + Math.random() * 150;
          // 高さと幅を再設定
          mountains[i].width = 150 + Math.random() * 100;
          mountains[i].y = canvas.height - blockHeight - (80 + Math.random() * 70); 
        }
      }
      // 雲のスクロール（速度は地面の0.2倍）
      for (let i = 0; i < clouds.length; i++) {
        clouds[i].x -= scrollSpeed * 0.2;
        if (clouds[i].x + clouds[i].size * 2 < 0) {
          clouds[i].x = canvas.width + Math.random() * 100;
          clouds[i].y = Math.random() * (canvas.height / 2);
        }
      }

      // --- 当たり判定（地面） ---
      let onGround = false;
      for (const block of blocks) {
        if (checkCollision(player, block)) {
          // 上から乗った場合
          if (player.vy > 0 && player.y + player.height - player.vy <= block.y + 5) {
            player.y = block.y - player.height;
            player.vy = 0;
            player.jumpCount = 0; // 着地したらジャンプ回数をリセット
            onGround = true;
          } else {
            // 横からぶつかった場合（壁としてゲームオーバー）
            gameOver();
            return;
          }
        }
      }

      // --- 当たり判定（障害物） ---
      for (const obs of obstacles) {
        if (checkCollision(player, obs)) {
          gameOver();
          return;
        }
      }

      // --- 落下判定 ---
      if (player.y > canvas.height) {
        gameOver();
        return;
      }

      // --- メモリ最適化＆新しいブロックの生成 ---
      // 画面外に出たブロックを削除
      blocks = blocks.filter(b => b.x + b.width > 0);
      obstacles = obstacles.filter(o => o.x + o.width > 0);

      // 穴を正しく管理するため、nextBlockXをスクロール量に合わせて減算
      nextBlockX -= scrollSpeed;
      
      // nextBlockX が画面右端に近づいたら新しいブロックを生成
      while (nextBlockX < canvas.width + blockWidth) {
        // 穴を作る確率（15%）
        const isHole = Math.random() < 0.15;
        
        if (!isHole) {
          const groundY = canvas.height - blockHeight;
          blocks.push({
            x: nextBlockX,
            y: groundY,
            width: blockWidth,
            height: blockHeight
          });

          // 障害物を作る確率（10%）
          if (Math.random() < 0.10 && nextBlockX > canvas.width) {
            obstacles.push({
              x: nextBlockX + blockWidth / 2 - 15,
              y: groundY - 30, // 地面の上に乗るように配置
              width: 30,
              height: 30
            });
          }
        }
        // ブロックを作っても作らなくても、次の座標を更新する（これで穴の空間が確保される）
        nextBlockX += blockWidth;
      }
    }

    function draw() {
      // Clear canvas
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      if (gameState === 'start') return;

      // Draw Mountains (背景・奥)
      ctx.fillStyle = '#2e8b57'; // 海洋緑っぽい色（背景の山用）
      for (const m of mountains) {
        ctx.beginPath();
        ctx.moveTo(m.x, m.y); // 山の頂点
        ctx.lineTo(m.x - m.width / 2, canvas.height - blockHeight); // 左下（地面の高さ）
        ctx.lineTo(m.x + m.width / 2, canvas.height - blockHeight); // 右下
        ctx.fill();
      }

      // Draw Clouds (背景・空)
      ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
      for (const c of clouds) {
        ctx.beginPath();
        ctx.arc(c.x, c.y, c.size, 0, Math.PI * 2);
        ctx.arc(c.x + c.size, c.y - c.size * 0.2, c.size * 0.8, 0, Math.PI * 2);
        ctx.arc(c.x + c.size * 1.5, c.y, c.size * 0.9, 0, Math.PI * 2);
        ctx.fill();
      }

      // Draw Blocks (Ground)
      ctx.fillStyle = '#28a745'; // 緑色
      for (const block of blocks) {
        ctx.fillRect(block.x, block.y, block.width, block.height);
      }

      // Draw Obstacles
      ctx.fillStyle = '#dc3545'; // 赤色
      for (const obs of obstacles) {
        ctx.fillRect(obs.x, obs.y, obs.width, obs.height);
      }
      
      // Draw Player (Blue Square)
      ctx.fillStyle = '#007bff';
      ctx.fillRect(player.x, player.y, player.width, player.height);
    }

    function loop() {
      update();
      draw();
      requestAnimationFrame(loop);
    }

    // Input Handling
    function handleTap(e) {
      if (e) {
        if (e.target.tagName.toLowerCase() === 'button') return;
        e.preventDefault();
      }

      if (gameState === 'playing') {
        // Jump Logic (2段ジャンプ)
        if (player.jumpCount < player.maxJumps) {
          player.vy = jumpPower;
          player.jumpCount++;
        }
      } else if (gameState === 'start') {
        startGame();
      }
    }

    // wrapperに対してイベントを貼ることでCanvas領域内のタップを取得
    wrapper.addEventListener('mousedown', handleTap);
    wrapper.addEventListener('touchstart', handleTap, { passive: false });

    function startGame() {
      gameState = 'playing';
      startScreen.style.display = 'none';
      resultScreen.style.display = 'none';
      
      startTime = Date.now();
      survivalTime = 0;
      timeElement.textContent = '0.0';
      scrollSpeed = 5;

      // Reset Player
      player.y = canvas.height - blockHeight - player.height;
      player.vy = 0;
      player.jumpCount = 0;

      // Reset World (初期状態は穴なしで地面を敷き詰める)
      blocks = [];
      obstacles = [];
      
      // 背景の初期配置
      mountains = [];
      for(let i=0; i<3; i++) {
        const w = 150 + Math.random() * 100;
        mountains.push({
          x: Math.random() * canvas.width,
          y: canvas.height - blockHeight - (80 + Math.random() * 70), // 山の高さ
          width: w
        });
      }
      
      clouds = [];
      for(let i=0; i<4; i++) {
        clouds.push({
          x: Math.random() * canvas.width,
          y: Math.random() * (canvas.height / 2),
          size: 20 + Math.random() * 20
        });
      }

      nextBlockX = 0;
      for (let x = 0; x < canvas.width + blockWidth; x += blockWidth) {
        blocks.push({
          x: nextBlockX,
          y: canvas.height - blockHeight,
          width: blockWidth,
          height: blockHeight
        });
        nextBlockX += blockWidth;
      }
    }

    function gameOver() {
      gameState = 'gameover';
      resultScreen.style.display = 'flex';
      
      finalTimeElement.textContent = survivalTime.toFixed(1);
      
      if (survivalTime > highScore) {
        highScore = survivalTime;
        localStorage.setItem('runaction_highscore', highScore.toString());
        highscoreElement.textContent = highScore.toFixed(1);
      }

      // Update Share Button
      const shareText = `生存時間 ${survivalTime.toFixed(1)} 秒！(ベスト: ${highScore.toFixed(1)}秒) #MyPortfolioAction`;
      const shareUrl = window.location.href;
      const twitterUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`;
      
      // ボタンイベントの再登録（重複防止）
      const newShareBtn = shareBtn.cloneNode(true);
      shareBtn.parentNode.replaceChild(newShareBtn, shareBtn);
      newShareBtn.addEventListener('click', () => {
        window.open(twitterUrl, '_blank', 'noopener,noreferrer');
      });
    }

    startBtn.addEventListener('click', (e) => { e.stopPropagation(); startGame(); });
    retryBtn.addEventListener('click', (e) => { e.stopPropagation(); startGame(); });

    // Start loop
    requestAnimationFrame(loop);
  })();
</script>
