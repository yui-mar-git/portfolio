---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { fetchMicroCMS } from '../../../lib/microcms';
import type { MicroCMSListResponse, MicroCMSPortfolio } from '../../../types/microcms';

const portfolioResponse = await fetchMicroCMS<MicroCMSListResponse<MicroCMSPortfolio>>('portfolio');
  const projectData = portfolioResponse.contents.find((c) => c.url.includes('/roguelike/'));

  const techStack = [
  { category: "開発言語", items: "HTML, CSS, JavaScript" },
  { category: "フレームワーク", items: "Astro" },
  { category: "その他ツール", items: "Claude, Gemini" }
  ];

  const learningThemes = ["状態管理", "ダメージ計算", "ターン制ロジック", "デッキ構築", "ローグライク設計"];

  const materialCategories = [
  { category: "画像素材", items: [{ name: "いらすとや", url: "https://www.irasutoya.com/" }] },
  { category: "音楽・効果音", items: [
    { name: "魔王魂", url: "https://maou.audio/" },
    { name: "効果音ラボ", url: "https://soundeffect-lab.info/" }
  ] },
  { category: "フォント", items: [{ name: "Google Fonts", url: "https://fonts.google.com/" }] },
  { category: "アイコン", items: [{ name: "Simple Icons", url: "https://simpleicons.org/" }] }
  ];
  ---

  <BaseLayout title="ローグライクカードゲーム - My Portfolio" pageId="roguelike">
    <Header activeId="portfolio" />

    <main class="container">
      <div class="game-container" style="position: relative; height: 580px; overflow: hidden;" id="game-container">
        <span id="config-btn" class="icon-config" title="コンフィグ" style="position:absolute; top:0.5rem; right:0.5rem; z-index: 999;">⚙️</span>

        <!-- ゲームヘッダーバー（ステータス常時表示） -->
        <div id="game-header" class="game-header-bar"
          style="display: none; justify-content: space-between; align-items: center; background: rgba(15,15,26,0.95); border-bottom: 1px solid #333; padding: 0.4rem 2.5rem 0.4rem 0.8rem; font-size: 0.78rem; z-index: 100;">
          <div class="header-status" style="display: flex; gap: 0.8rem; align-items: center;">
            <span id="header-floor" style="font-weight: bold; color: #ffb84d;">エリア 1 - 0層</span>
            <span class="gold-badge" style="color: #ffd700; font-weight: bold;">💰<span
                id="header-gold">50</span></span>
            <span class="hp-badge" style="color: #ff6b6b; font-weight: bold;">❤️<span id="header-hp">10/10</span></span>
            <span class="mp-badge" style="color: #7cc5ff; font-weight: bold;">💧<span id="header-mp">5/5</span></span>
            <div class="header-relics" style="display: flex; gap: 4px; align-items: center; margin-left: 0.5rem;">
              <span style="font-size: 0.7rem; color: var(--text-muted);">レリック:</span>
              <div id="header-relics-list" style="display: flex; gap: 4px;"></div>
            </div>
          </div>
        </div>

        <!-- ゲームオーバー/クリア画面 -->
        <div class="overlay" id="result-overlay"
          style="display: none; background-color: rgba(0,0,0,0.95); z-index: 200;">
          <h2 id="result-title">戦闘終了</h2>
          <p id="result-details"
            style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem; text-align: center; line-height: 1.5;">
          </p>
          <div class="result-actions">
            <button class="btn btn-primary" id="btn-next">次の戦闘へ</button>
            <button class="btn btn-secondary" id="btn-title">タイトルへ</button>
            <button class="btn" id="btn-share"
              style="background-color: #1DA1F2; border-color: #1DA1F2; color:white;">Xでシェア</button>
          </div>
        </div>

        <!-- カード選択報酬画面 -->
        <div class="overlay" id="reward-overlay"
          style="display: none; background-color: rgba(0,0,0,0.95); z-index: 180;">
          <h2>🎉 戦闘勝利！</h2>
          <p class="reward-subtitle" id="reward-subtitle-text">1枚カードを選んでデッキに追加</p>
          <div id="reward-cards" class="reward-cards"></div>
          <button class="btn btn-secondary" id="btn-skip-reward" style="margin-top:1rem;">スキップ</button>
        </div>

        <!-- デッキ閲覧モーダル -->
        <div class="overlay" id="deck-viewer-overlay"
          style="display: none; background-color: rgba(0,0,0,0.95); justify-content: flex-start; padding-top: 2.5rem; z-index: 190;">
          <h2 style="color: white; margin-bottom: 0.5rem; font-size: 1.2rem;">デッキ確認</h2>
          <div class="deck-viewer-tabs">
            <button class="deck-tab active" data-target="deck-list">山札 (<span id="dv-deck-count">0</span>)</button>
            <button class="deck-tab" data-target="discard-list">捨て札 (<span id="dv-discard-count">0</span>)</button>
            <button class="deck-tab" data-target="hand-list">手札 (<span id="dv-hand-count">0</span>)</button>
          </div>
          <div id="deck-list" class="dv-card-list active"></div>
          <div id="discard-list" class="dv-card-list"></div>
          <div id="hand-list" class="dv-card-list"></div>
          <button class="btn btn-secondary" id="close-deck-viewer" style="margin-top:0.8rem; width:100%;">閉じる</button>
        </div>

        <!-- スタート画面 -->
        <div id="start-screen"
          style="position:absolute; top:0; left:0; width:100%; height:100%; background:#0f0f1a; z-index:99; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:1.5rem; box-sizing:border-box;">
          <h2 style="font-size: 1.8rem; margin-bottom: 0.3rem;">ローグライクカードゲーム</h2>
          <p style="color: var(--text-muted); margin-bottom:2rem; font-size: 0.85rem;">職業・属性・状態異常・ゴールドを駆使する本格ローグライク<br>※スタートするとBGMが鳴ります</p>
          <button id="start-btn" class="btn btn-full">冒険を始める</button>
          <button id="howto-btn" class="btn btn-secondary" style="margin-top: 1rem; width: 100%;">遊び方</button>
        </div>

        <!-- 職業選択画面 -->
        <div id="class-select-screen"
          style="position:absolute; top:0; left:0; width:100%; height:100%; background:#0f0f1a; z-index:98; display:none; flex-direction:column; padding:1.2rem; box-sizing:border-box; overflow-y:auto;">
          <h2 style="font-size: 1.2rem; text-align: center; margin-bottom: 0.4rem; color: #ffb84d;">冒険者の選択</h2>
          <p style="font-size: 0.7rem; color: var(--text-muted); text-align: center; margin-bottom: 0.8rem;">
            あなたの戦闘スタイルを選んで旅立ちましょう。</p>
          <div style="flex: 1;">
            <div class="class-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;">
              <div class="class-card" data-class="yuusya">
                <img src="/portfolio/roguelike/assets/characters/figure_rpg_character_yuusya.png"
                  style="width: 40px; height: 40px; object-fit: contain; margin-bottom: 0.3rem;" />
                <div style="font-size: 0.85rem; font-weight: bold;">勇者</div>
                <div style="font-size: 0.62rem; color: var(--text-muted); line-height: 1.3; margin-top: 0.25rem;">HP10 /
                  MP5<br>初期レリックが+1個</div>
              </div>
              <div class="class-card" data-class="kenshi">
                <img src="/portfolio/roguelike/assets/characters/figure_rpg_character_kenshi.png"
                  style="width: 40px; height: 40px; object-fit: contain; margin-bottom: 0.3rem;" />
                <div style="font-size: 0.85rem; font-weight: bold;">戦士</div>
                <div style="font-size: 0.62rem; color: var(--text-muted); line-height: 1.3; margin-top: 0.25rem;">HP15 /
                  MP4<br>毎ターンHP+1回復</div>
              </div>
              <div class="class-card" data-class="mahoutsukai">
                <img src="/portfolio/roguelike/assets/characters/figure_rpg_character_mahoutsukai.png"
                  style="width: 40px; height: 40px; object-fit: contain; margin-bottom: 0.3rem;" />
                <div style="font-size: 0.85rem; font-weight: bold;">魔法使い</div>
                <div style="font-size: 0.62rem; color: var(--text-muted); line-height: 1.3; margin-top: 0.25rem;">HP7 /
                  MP7<br>毎ターンMP+1回復</div>
              </div>
              <div class="class-card" data-class="butouka">
                <img src="/portfolio/roguelike/assets/characters/figure_rpg_character_butouka.png"
                  style="width: 40px; height: 40px; object-fit: contain; margin-bottom: 0.3rem;" />
                <div style="font-size: 0.85rem; font-weight: bold;">格闘家</div>
                <div style="font-size: 0.62rem; color: var(--text-muted); line-height: 1.3; margin-top: 0.25rem;">HP8 /
                  MP4<br>毎ターン行動回数+1</div>
              </div>
            </div>
            <p id="class-select-preview"
              style="font-size: 0.7rem; color: #ffb84d; text-align: center; margin-top: 0.8rem; min-height: 1.2rem;">
              勇者が選択されています</p>
          </div>

          <button id="btn-game-start" class="btn btn-full" style="margin-top: 0.5rem;">冒険の旅へ出る</button>
        </div>

        <!-- マップ進行画面（横スクロール双六マップ） -->
        <div id="map-screen"
          style="position:absolute; top:40px; left:0; width:100%; height:calc(100% - 40px); background:#0f0f1a; z-index:80; display:none; flex-direction:column; padding:1rem; box-sizing:border-box; justify-content: space-between;">
          <div style="text-align: center; margin-bottom: 0.3rem;">
            <h3 style="font-size: 1.1rem; color: #ffb84d; margin-bottom: 0.1rem;">マップ</h3>
          </div>

          <!-- 横スクロールすごろく本体 -->
          <div id="map-scroll-wrapper"
            style="flex: 1; overflow-x: auto; overflow-y: hidden; display: flex; align-items: center; background: rgba(0,0,0,0.3); border: 1px solid #333; border-radius: 8px; padding: 1.5rem 1rem; margin-bottom: 0.8rem; position: relative;">
            <div id="map-board"
              style="display: flex; gap: 40px; align-items: center; position: relative; min-width: max-content;">
              <!-- JSですごろくノードが左から右に動的描画されます。接続線はCSSまたはSVG -->
            </div>
          </div>

          <div
            style="border-top: 1px solid #333; padding-top: 0.4rem; display: flex; justify-content: space-between; align-items: center;">
            <button class="btn btn-secondary" id="btn-map-view-deck"
              style="font-size: 0.72rem; padding: 0.3rem 0.8rem;">デッキ確認</button>
            <span style="font-size: 0.65rem; color: var(--text-muted);">接続された次のマスへ進めます</span>
          </div>
        </div>

        <!-- 宿（回復）画面 -->
        <div id="inn-screen"
          style="position:absolute; top:40px; left:0; width:100%; height:calc(100% - 40px); background:#0c1513; z-index:81; display:none; flex-direction:column; align-items:center; justify-content:center; padding:1.5rem; box-sizing:border-box; text-align:center;">
          <img src="/portfolio/roguelike/assets/map/building_hotel_pet.png"
            style="width: 64px; height: 64px; object-fit: contain; margin-bottom: 1rem;" />
          <h3 style="color: #51cf66; font-size: 1.2rem; margin-bottom: 0.5rem;">旅人の宿</h3>
          <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 1.5rem; max-width: 80%;">
            15ゴールドを支払って、宿屋でぐっすり休むことができます。<br>
            <strong>効果: HP全回復 ＋ 毒/麻痺の全治</strong>
          </p>
          <div style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
            <button id="btn-inn-rest" class="btn btn-primary" style="width: 100%;">休む (💰15)</button>
            <button id="btn-inn-leave" class="btn btn-secondary" style="width: 100%;">立ち去る</button>
          </div>
        </div>

        <!-- 妖精（強化）画面 -->
        <div id="fairy-screen"
          style="position:absolute; top:40px; left:0; width:100%; height:calc(100% - 40px); background:#150f1a; z-index:82; display:none; flex-direction:column; padding:1.2rem; box-sizing:border-box; justify-content: space-between;">
          <div style="text-align: center;">
            <img src="/portfolio/roguelike/assets/characters/fantasy_pixy2.png"
              style="width: 64px; height: 64px; object-fit: contain; margin-bottom: 0.5rem;" />
            <h3 style="color: #cc5de8; font-size: 1.2rem; margin-bottom: 0.2rem;">祝福の妖精</h3>
            <p id="fairy-desc" style="font-size: 0.75rem; color: var(--text-muted);">
              20ゴールドを支払い、妖精の魔力で手札のカードを1枚「強化（+）」します。</p>
          </div>

          <!-- 強化対象カード選択リスト -->
          <div id="fairy-card-list"
            style="flex: 1; overflow-y: auto; margin: 1rem 0; display: grid; grid-template-columns: repeat(6, 1fr); gap: 6px; padding: 4px; border: 1px solid #333; border-radius: 6px; background: rgba(0,0,0,0.3); max-height: 250px;">
            <!-- 所持カードがボタンとして並びます -->
          </div>

          <div style="display: flex; gap: 8px; width: 100%;">
            <button id="btn-fairy-leave" class="btn btn-secondary" style="flex: 1;">立ち去る</button>
          </div>
        </div>

        <!-- 街（ショップ）画面 -->
        <div id="town-screen"
          style="position:absolute; top:40px; left:0; width:100%; height:calc(100% - 40px); background:#1a150f; z-index:83; display:none; flex-direction:column; padding:1.2rem; box-sizing:border-box; justify-content: space-between;">
          <div style="text-align: center;">
            <img src="/portfolio/roguelike/assets/map/omise_shop_tatemono.png"
              style="width: 64px; height: 64px; object-fit: contain; margin-bottom: 0.5rem;" />
            <h3 style="color: #ff922b; font-size: 1.2rem; margin-bottom: 0.2rem;">よろず街の商い</h3>
            <p style="font-size: 0.75rem; color: var(--text-muted);">ゴールドを支払い、アイテムやカードを仕入れることができます。</p>
          </div>

          <div
            style="flex: 1; display: flex; flex-direction: column; gap: 10px; margin: 0.8rem 0; overflow-y: auto; max-height: 280px;">
            <div>
              <p
                style="font-size: 0.72rem; color: #ff922b; font-weight: bold; margin-bottom: 0.3rem; border-bottom: 1px solid #444;">
                販売カード (各 💰15)</p>
              <div id="town-cards" style="display: flex; gap: 6px; overflow-x: auto; padding: 4px 0;"></div>
            </div>
            <div>
              <p
                style="font-size: 0.72rem; color: #ffd8a8; font-weight: bold; margin-bottom: 0.3rem; border-bottom: 1px solid #444;">
                販売アイテム (各 💰20)</p>
              <div id="town-items" style="display: flex; gap: 6px; overflow-x: auto; padding: 4px 0;"></div>
            </div>
          </div>

          <button id="btn-town-leave" class="btn btn-secondary" style="width: 100%;">街を出る</button>
        </div>

        <!-- イベント画面 -->
        <div id="event-screen"
          style="position:absolute; top:40px; left:0; width:100%; height:calc(100% - 40px); background:#11111a; z-index:84; display:none; flex-direction:column; padding:1.5rem; box-sizing:border-box; justify-content: space-between; text-align: center;">
          <div>
            <img id="event-image" src="/portfolio/roguelike/assets/icons/no_image_square.jpg"
              style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; margin-bottom: 1rem; border: 1px solid #444;" />
            <h3 id="event-title" style="color: #ffb84d; font-size: 1.2rem; margin-bottom: 0.5rem;">未知のイベント</h3>
            <p id="event-text"
              style="font-size: 0.82rem; color: var(--text-muted); line-height: 1.6; max-width: 90%; margin: 1rem auto;">
            </p>
          </div>

          <div id="event-options" style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
            <!-- イベントの選択肢ボタンがJSで動的に追加されます -->
          </div>
        </div>

        <!-- アイテム使用確認モーダル -->
        <div id="item-confirm-modal"
          style="position:absolute; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:300; display:none; flex-direction:column; align-items:center; justify-content:center; padding:1.5rem; box-sizing:border-box;">
          <div
            style="background: #151522; border: 1px solid #444; border-radius: 8px; padding: 1.2rem; width: 85%; max-width: 320px; text-align: center;">
            <h4 style="font-size: 1rem; color: #ffb84d; margin-bottom: 0.4rem;">アイテムの使用確認</h4>
            <p id="item-confirm-text"
              style="font-size: 0.78rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 1.2rem;"></p>
            <div style="display: flex; gap: 10px;">
              <button id="btn-item-confirm-yes" class="btn btn-primary" style="flex: 1; padding: 0.4rem 0;">はい</button>
              <button id="btn-item-confirm-no" class="btn btn-secondary"
                style="flex: 1; padding: 0.4rem 0;">いいえ</button>
            </div>
          </div>
        </div>

        <!-- 戦闘中マップ確認モーダル -->
        <div id="battle-map-overlay" class="overlay"
          style="display: none; background-color: rgba(0,0,0,0.9); z-index: 250; padding: 1rem; flex-direction: column;">
          <h3 style="color: #ffb84d; font-size: 1.1rem; text-align: center; margin-bottom: 0.5rem;">現在地確認 🗺️</h3>
          <div id="battle-map-scroll-wrapper"
            style="flex: 1; overflow-x: auto; overflow-y: hidden; display: flex; align-items: center; background: rgba(0,0,0,0.3); border: 1px solid #333; border-radius: 8px; padding: 1.5rem 1rem;">
            <div id="battle-map-board"
              style="display: flex; gap: 40px; align-items: center; position: relative; min-width: max-content;"></div>
          </div>
          <button class="btn btn-secondary" id="btn-close-battle-map"
            style="margin-top: 0.8rem; width: 100%;">閉じる</button>
        </div>

        <!-- 王様遭遇イベントモーダル -->
        <div id="king-event-modal" class="overlay"
          style="display: none; background-color: rgba(15,15,26,0.98); z-index: 210; flex-direction: column; align-items: center; justify-content: center; padding: 1.5rem; text-align: center;">
          <img src="/portfolio/roguelike/assets/characters/royal_king.png"
            style="width: 80px; height: 80px; object-fit: contain; margin-bottom: 1rem;" />
          <h3 style="color: #ffd700; font-size: 1.2rem; margin-bottom: 0.4rem;">謁見の間：王からの餞別</h3>
          <p
            style="font-size: 0.8rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 1.5rem; max-width: 80%;">
            「よくぞ来た、勇猛なる旅人よ。この地に巣食う魔王を討ち果たすのだ。<br>お前にこの伝説の遺物（レリック）から一つを授けよう…」
          </p>
          <div id="king-relic-choices" style="display: flex; gap: 10px; margin-bottom: 1.5rem;">
            <!-- 3つのレリック選択カードがJSで挿入されます -->
          </div>
        </div>

        <!-- 汎用カットシーンモーダル -->
        <div id="cutscene-modal" class="overlay"
          style="display: none; background: rgba(5,5,20,0.97); z-index: 300; flex-direction: column; align-items: center; justify-content: flex-end; padding-bottom: 2rem;">
          <!-- 背景イメージ -->
          <div id="cutscene-bg"
            style="position:absolute; inset:0; background-size:cover; background-position:center; opacity:0.25; pointer-events:none;">
          </div>
          <!-- キャラクターポートレート群 -->
          <div id="cutscene-portraits"
            style="position:absolute; bottom:120px; left:0; right:0; display:flex; align-items:flex-end; justify-content:center; gap:20px; pointer-events:none; z-index:2;">
          </div>
          <!-- セリフウィンドウ -->
          <div
            style="position:relative; z-index:3; width:92%; max-width:420px; background:rgba(10,8,25,0.92); border:2px solid #6a5acd; border-radius:12px; padding:1rem 1.2rem 0.8rem; box-shadow:0 0 30px rgba(106,90,205,0.4);">
            <div id="cutscene-speaker"
              style="font-size:0.72rem; font-weight:bold; color:#c9b8ff; margin-bottom:0.3rem; min-height:1em;"></div>
            <div id="cutscene-text" style="font-size:0.78rem; color:#e8e0ff; line-height:1.7; min-height:3.2em;"></div>
            <div style="text-align:right; margin-top:0.5rem;">
              <button id="btn-cutscene-next" class="btn btn-primary" style="font-size:0.7rem; padding:0.25rem 1rem;">次へ
                ▶</button>
            </div>
          </div>
        </div>

        <!-- ゲーム内汎用メッセージダイアログ -->

        <div id="game-dialog-modal" class="overlay"
          style="display: none; background-color: rgba(0,0,0,0.85); z-index: 500; align-items: center; justify-content: center; padding: 1.5rem;">
          <div
            style="background: #151522; border: 2px solid #555; border-radius: 10px; padding: 1.2rem; width: 85%; max-width: 320px; text-align: center; box-shadow: 0 0 15px rgba(0,0,0,0.5);">
            <h4 id="dialog-title" style="font-size: 1rem; color: #ffb84d; margin-bottom: 0.5rem; font-weight: bold;">通知
            </h4>
            <p id="dialog-message" style="font-size: 0.78rem; color: #eee; line-height: 1.5; margin-bottom: 1.2rem;">
            </p>
            <div id="dialog-buttons" style="display: flex; gap: 10px; justify-content: center;">
              <button id="btn-dialog-ok" class="btn btn-primary" style="padding: 0.3rem 1.5rem;">OK</button>
              <button id="btn-dialog-yes" class="btn btn-primary"
                style="display:none; flex:1; padding: 0.3rem 0;">はい</button>
              <button id="btn-dialog-no" class="btn btn-secondary"
                style="display:none; flex:1; padding: 0.3rem 0;">いいえ</button>
            </div>
          </div>
        </div>

        <!-- バトル画面本体 -->
        <div class="battle-layout"
