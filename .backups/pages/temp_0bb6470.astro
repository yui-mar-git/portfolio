---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { fetchMicroCMS } from '../../../lib/microcms';
import type { MicroCMSListResponse, MicroCMSPortfolio } from '../../../types/microcms';

const portfolioResponse = await fetchMicroCMS<MicroCMSListResponse<MicroCMSPortfolio>>('portfolio');
  const projectData = portfolioResponse.contents.find((c) => c.url.includes('/tower-defense/'));

  const techStack = [
  { category: "開発言語", items: "HTML, CSS, JavaScript" },
  { category: "フレームワーク", items: "Astro, Phaser 3 (ゲームエンジン)" },
  { category: "その他ツール", items: "Google Antigravity, Gemini, Claude" }
  ];

  const learningThemes = ["ゲームエンジン(Phaser 3)基礎", "Arcade Physicsによる衝突判定"];

  const materialCategories = [
  { category: "フォント", items: [{ name: "Google Fonts", url: "https://fonts.google.com/" }] },
  { category: "アイコン", items: [{ name: "Simple Icons", url: "https://simpleicons.org/" }] },
  { category: "音楽・効果音", items: [{ name: "効果音ラボ", url: "https://soundeffect-lab.info/" }] }
  ];
  ---

  <BaseLayout title="タワーディフェンス - My Portfolio" pageId="tower-defense">
    <!-- Phaser 3 の CDN 読み込み -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/phaser@3.60.0/dist/phaser.min.js"></script>